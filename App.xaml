<Application x:Class="Metrologo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:Metrologo.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Couleurs de marque ASERTI -->
            <Color x:Key="AsertiOrangeColor">#E89B2F</Color>
            <Color x:Key="AsertiOrangeDarkColor">#C47F1E</Color>
            <Color x:Key="AsertiOrangeLightColor">#F5B856</Color>
            <Color x:Key="AsertiNavyColor">#1E2D4F</Color>
            <Color x:Key="AsertiNavyDarkColor">#0F1A33</Color>
            <Color x:Key="AsertiNavyLightColor">#2E4372</Color>

            <SolidColorBrush x:Key="AsertiOrangeBrush" Color="{StaticResource AsertiOrangeColor}"/>
            <SolidColorBrush x:Key="AsertiOrangeDarkBrush" Color="{StaticResource AsertiOrangeDarkColor}"/>
            <SolidColorBrush x:Key="AsertiOrangeLightBrush" Color="{StaticResource AsertiOrangeLightColor}"/>
            <SolidColorBrush x:Key="AsertiNavyBrush" Color="{StaticResource AsertiNavyColor}"/>
            <SolidColorBrush x:Key="AsertiNavyDarkBrush" Color="{StaticResource AsertiNavyDarkColor}"/>
            <SolidColorBrush x:Key="AsertiNavyLightBrush" Color="{StaticResource AsertiNavyLightColor}"/>

            <LinearGradientBrush x:Key="AsertiNavyGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="0.6"/>
                <GradientStop Color="{StaticResource AsertiNavyLightColor}" Offset="1"/>
            </LinearGradientBrush>

            <!-- Ombres portées partagées — teintées navy plutôt que noir pur pour rester
                 dans la palette ASERTI. Posées sur un calque DERRIÈRE le contenu dans les
                 templates (jamais sur un élément contenant du texte : l'effet dégraderait
                 le rendu ClearType de tout le sous-arbre). -->
            <DropShadowEffect x:Key="CardShadow" BlurRadius="14" ShadowDepth="2" Direction="270"
                              Color="{StaticResource AsertiNavyColor}" Opacity="0.10"/>
            <DropShadowEffect x:Key="CardShadowHover" BlurRadius="22" ShadowDepth="5" Direction="270"
                              Color="{StaticResource AsertiNavyColor}" Opacity="0.20"/>
            <DropShadowEffect x:Key="AccentShadow" BlurRadius="12" ShadowDepth="2" Direction="270"
                              Color="{StaticResource AsertiOrangeColor}" Opacity="0.35"/>
            <DropShadowEffect x:Key="AccentShadowHover" BlurRadius="18" ShadowDepth="3" Direction="270"
                              Color="{StaticResource AsertiOrangeColor}" Opacity="0.50"/>
            <DropShadowEffect x:Key="BannerShadow" BlurRadius="20" ShadowDepth="4" Direction="270"
                              Color="{StaticResource AsertiNavyColor}" Opacity="0.25"/>

            <!-- Bouton de navigation (fond transparent sur navy) -->
            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="14,8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="White" Opacity="0.12"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="White" Opacity="0.22"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Bouton accent orange ASERTI -->
            <Style x:Key="NavAccentButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="{StaticResource AsertiOrangeBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="14,8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource AsertiOrangeDarkBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource AsertiOrangeDarkBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Carte d'action cliquable (Accueil) -->
            <Style x:Key="ActionCardStyle" TargetType="Button">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <!-- Calque d'ombre séparé derrière le contenu : l'effet ne touche
                                 pas le texte (préserve le rendu ClearType) et permet une
                                 élévation au survol sans re-layouter le contenu. -->
                            <Grid x:Name="root" RenderTransformOrigin="0.5,0.5">
                                <Border x:Name="shadow"
                                        CornerRadius="10"
                                        Background="White"
                                        Effect="{StaticResource CardShadow}"/>
                                <Border x:Name="b"
                                        CornerRadius="10"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Stretch"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                    <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                                    <Setter TargetName="shadow" Property="Effect" Value="{StaticResource CardShadowHover}"/>
                                    <Setter TargetName="root" Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform Y="-2"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                    <Setter TargetName="shadow" Property="Effect" Value="{x:Null}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Carte feature (Admin, non-cliquable). L'ombre est posée directement sur la
                 bordure (pas de template ici) : volontairement très douce pour limiter
                 l'impact sur le rendu du texte contenu. -->
            <Style x:Key="FeatureCardStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="18"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270"
                                          Color="{StaticResource AsertiNavyColor}" Opacity="0.08"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Section de formulaire (ConfigurationWindow) -->
            <Style x:Key="FormSectionStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="18"/>
                <Setter Property="Margin" Value="0,0,0,14"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270"
                                          Color="{StaticResource AsertiNavyColor}" Opacity="0.08"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Label de formulaire -->
            <Style x:Key="FormLabelStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            </Style>

            <!-- Titre de section -->
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,14"/>
                <Setter Property="Foreground" Value="{StaticResource AsertiNavyBrush}"/>
            </Style>

            <!-- Bouton primaire orange ASERTI -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AsertiOrangeBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <!-- Calque d'ombre séparé : ne touche pas le texte du bouton. -->
                                <Border x:Name="shadow"
                                        CornerRadius="6"
                                        Background="{TemplateBinding Background}"
                                        Effect="{StaticResource AccentShadow}"/>
                                <Border x:Name="b"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource AsertiOrangeDarkBrush}"/>
                                    <Setter TargetName="shadow" Property="Effect" Value="{StaticResource AccentShadowHover}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="shadow" Property="Effect" Value="{x:Null}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                    <Setter TargetName="shadow" Property="Effect" Value="{x:Null}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Bouton secondaire -->
            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource AsertiNavyBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AsertiNavyBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{StaticResource AsertiNavyColor}" Opacity="0.06"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        </ResourceDictionary>
    </Application.Resources>

</Application>
