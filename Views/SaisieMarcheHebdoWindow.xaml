<ui:FluentWindow x:Class="Metrologo.Views.SaisieMarcheHebdoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Marche hebdomadaire"
        Height="540" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Marche hebdomadaire" ShowMaximize="False"/>

        <Border Grid.Row="1" Padding="24,12,24,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10"
                        Background="{StaticResource AsertiNavyBrush}"
                        Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="Clock24" FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Saisie de la marche"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="{Binding RubidiumActifTexte}"
                               FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,0,24,16">
            <StackPanel>
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="VALEUR DE LA MARCHE (µs)" Style="{StaticResource FormLabelStyle}"/>
                        <ui:TextBox Text="{Binding MarcheTexte, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="0.0"
                                    FontFamily="Cascadia Mono, Consolas"
                                    FontSize="18"
                                    Padding="12,10">
                            <ui:TextBox.Icon>
                                <ui:SymbolIcon Symbol="NumberSymbol24"/>
                            </ui:TextBox.Icon>
                        </ui:TextBox>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="DATE DE LA MESURE" Style="{StaticResource FormLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding DateSelectionnee, Mode=TwoWay}"
                                    Padding="10,8" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DATE JULIENNE (MJD)" Style="{StaticResource FormLabelStyle}"/>
                                <ui:TextBox Text="{Binding DateJulienne}"
                                            IsReadOnly="True"
                                            FontFamily="Cascadia Mono, Consolas"
                                            Padding="10,8"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Nº SEMAINE" Style="{StaticResource FormLabelStyle}"/>
                                <ui:TextBox Text="{Binding NumeroSemaine}"
                                            IsReadOnly="True"
                                            FontFamily="Cascadia Mono, Consolas"
                                            Padding="10,8"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border CornerRadius="6" Padding="12,10"
                        Background="#FFFEE2E2"
                        BorderBrush="#FFFCA5A5"
                        BorderThickness="1"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Warning24" FontSize="16"
                                       Foreground="#FFDC2626"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding MessageErreur}"
                                   Foreground="#FF7F1D1D"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3"
                Padding="24,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="Annuler"
                        Command="{Binding AnnulerCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Column="2"
                        Content="Valider"
                        Command="{Binding ValiderCommand}"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
