<ui:FluentWindow x:Class="Metrologo.Views.ChangerRoleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Changer le rôle"
        Height="540" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Icon="/Resources/logo.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Changer le rôle" ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/logo.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- En-tête utilisateur cible -->
        <Border Grid.Row="1" CornerRadius="10" Padding="16,12" Margin="20,16,20,8"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Border Width="40" Height="40" CornerRadius="20" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                            <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock x:Name="TbInitiales" Foreground="White" FontWeight="Bold" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TbNomComplet" FontWeight="SemiBold" FontSize="14"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock x:Name="TbLogin" FontFamily="Consolas" FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Options de rôle -->
        <StackPanel Grid.Row="2" Margin="20,8,20,8">

            <RadioButton x:Name="RbUtilisateur" GroupName="Role" Margin="0,0,0,8" Padding="0">
                <Border CornerRadius="8" Padding="14,12" BorderThickness="1"
                        Background="White"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="10"
                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                Margin="0,0,12,0">
                            <ui:SymbolIcon Symbol="Person24" FontSize="18"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Utilisateur"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource AsertiNavyBrush}"/>
                            <TextBlock Text="Accès aux mesures uniquement — pas d'accès à la zone d'administration."
                                       FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </RadioButton>

            <RadioButton x:Name="RbAdministrateur" GroupName="Role" Margin="0,0,0,8" Padding="0">
                <Border CornerRadius="8" Padding="14,12" BorderThickness="1"
                        Background="White"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="10"
                                Background="{StaticResource AsertiOrangeBrush}"
                                Margin="0,0,12,0">
                            <ui:SymbolIcon Symbol="ShieldKeyhole24" FontSize="18"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Administrateur"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource AsertiNavyBrush}"/>
                            <TextBlock Text="Accès complet à l'administration sauf la gestion des rôles et du mot de passe admin."
                                       FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </RadioButton>

            <RadioButton x:Name="RbSuperAdmin" GroupName="Role" Padding="0">
                <Border CornerRadius="8" Padding="14,12" BorderThickness="1"
                        Background="White"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="10"
                                Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                                    <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ui:SymbolIcon Symbol="Star24" FontSize="18"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Super-administrateur"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource AsertiNavyBrush}"/>
                            <TextBlock Text="Le « chef » — peut tout faire, y compris promouvoir d'autres admins et changer le mot de passe admin."
                                       FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </RadioButton>
        </StackPanel>

        <Border Grid.Row="3" Padding="20,12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Annuler" Click="OnAnnuler"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Column="2" Content="Enregistrer" Click="OnValider"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
