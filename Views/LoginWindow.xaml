<Window x:Class="Metrologo.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Authentification - Metrologo" Height="350" Width="300"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid>
        <StackPanel Margin="20,40,20,20" VerticalAlignment="Center">
            
            <TextBlock FontSize="24" FontWeight="Bold" Text="Connexion" HorizontalAlignment="Center" Margin="0,0,0,20" />

            <TextBlock Text="Identifiant :"/>
            <TextBox Text="{Binding LoginStr, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Padding="5"/>

            <TextBlock Text="Mot de passe :"/>
            <PasswordBox x:Name="txtMotDePasse" Margin="0,5,0,20" Padding="5"/>

            <TextBlock Text="{Binding MessageErreur}" Foreground="Red" TextAlignment="Center" Margin="0,0,0,10"/>

            <Button Content="Se connecter" Click="BtnConnexion_Click" IsDefault="True" Background="#0078D7" Foreground="White" HorizontalAlignment="Stretch" Margin="0,0,0,10"/>
            <Button Content="Quitter" Command="{Binding QuitterCommand}" HorizontalAlignment="Stretch" />
            
        </StackPanel>
    </Grid>
</Window>