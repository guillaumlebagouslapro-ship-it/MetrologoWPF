<ui:FluentWindow x:Class="Metrologo.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Authentification - ASERTI Metrology" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.ColumnSpan="2" Grid.Row="0" Title="ASERTI Metrology" ShowMaximize="False"/>

        <!-- Panneau gauche : branding ASERTI -->
        <Border Grid.Column="0" Grid.Row="1" Background="{StaticResource AsertiNavyGradient}">
            <Grid ClipToBounds="True">
                <!-- Cercles décoratifs -->
                <Ellipse Width="320" Height="320"
                         HorizontalAlignment="Right" VerticalAlignment="Top"
                         Margin="0,-90,-110,0" Opacity="0.10">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="{StaticResource AsertiOrangeColor}" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="260" Height="260"
                         HorizontalAlignment="Left" VerticalAlignment="Bottom"
                         Margin="-80,0,0,-70" Opacity="0.08">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Contenu branding -->
                <Grid Margin="48,20,48,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo ASERTI -->
                    <Border Grid.Row="0"
                            Background="White"
                            CornerRadius="12"
                            Padding="20,16"
                            HorizontalAlignment="Left"
                            Margin="0,16,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="Black" Opacity="0.25"/>
                        </Border.Effect>
                        <Image Source="/Resources/aserti-logo.png"
                               Height="48"
                               Stretch="Uniform"/>
                    </Border>

                    <!-- Tagline + features -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="Plateforme de"
                                   FontSize="22"
                                   FontWeight="Light"
                                   Foreground="White"/>
                        <TextBlock Text="métrologie de fréquence"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,-2,0,24"/>

                        <Border Width="48" Height="3"
                                Background="{StaticResource AsertiOrangeBrush}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,24"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="{StaticResource AsertiOrangeBrush}"
                                    Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="Pulse24" FontSize="18"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Mesures et analyses en temps réel"
                                       FontSize="13" VerticalAlignment="Center">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="White" Opacity="0.92"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="{StaticResource AsertiOrangeBrush}"
                                    Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="Timer24" FontSize="18"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Référence rubidium haute stabilité"
                                       FontSize="13" VerticalAlignment="Center">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="White" Opacity="0.92"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="{StaticResource AsertiOrangeBrush}"
                                    Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="DataTrending24" FontSize="18"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Rapports d'incertitudes automatisés"
                                       FontSize="13" VerticalAlignment="Center">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="White" Opacity="0.92"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Footer branding -->
                    <TextBlock Grid.Row="2"
                               Text="© ASERTI — Precision Metrology"
                               FontSize="11">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="White" Opacity="0.5"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>

        <!-- Panneau droit : formulaire -->
        <Border Grid.Column="1" Grid.Row="1" Background="{DynamicResource ApplicationBackgroundBrush}">
            <StackPanel Margin="56,24,56,32" VerticalAlignment="Center">

                <TextBlock Text="Bienvenue"
                           FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource AsertiNavyBrush}"/>
                <TextBlock Text="Connectez-vous pour accéder à votre espace de mesure"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,32"/>

                <TextBlock Text="IDENTIFIANT"
                           FontWeight="SemiBold"
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,6"/>
                <ui:TextBox Text="{Binding LoginStr, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Votre nom d'utilisateur"
                            Padding="10,8"
                            Margin="0,0,0,18">
                    <ui:TextBox.Icon>
                        <ui:SymbolIcon Symbol="Person24"/>
                    </ui:TextBox.Icon>
                </ui:TextBox>

                <TextBlock Text="MOT DE PASSE"
                           FontWeight="SemiBold"
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,6"/>
                <ui:PasswordBox x:Name="txtMotDePasse"
                                PlaceholderText="••••••••"
                                Padding="10,8"
                                Margin="0,0,0,10">
                    <ui:PasswordBox.Icon>
                        <ui:SymbolIcon Symbol="LockClosed24"/>
                    </ui:PasswordBox.Icon>
                </ui:PasswordBox>

                <TextBlock Text="{Binding MessageErreur}"
                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                           TextWrapping="Wrap"
                           FontSize="12"
                           Margin="0,4,0,16"/>

                <!-- Bouton CTA orange ASERTI -->
                <Button Click="BtnConnexion_Click"
                        IsDefault="True"
                        HorizontalAlignment="Stretch"
                        Padding="0,12"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,12">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    CornerRadius="6"
                                    Background="{StaticResource AsertiOrangeBrush}"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="Se connecter"
                                               VerticalAlignment="Center"
                                               FontSize="{TemplateBinding FontSize}"
                                               FontWeight="{TemplateBinding FontWeight}"
                                               Foreground="White"/>
                                    <ui:SymbolIcon Symbol="ArrowRight24"
                                                   FontSize="16"
                                                   Foreground="White"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource AsertiOrangeDarkBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource AsertiOrangeDarkBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <ui:Button Content="Quitter l'application"
                           Command="{Binding QuitterCommand}"
                           Appearance="Transparent"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Center"
                           Padding="0,8"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
