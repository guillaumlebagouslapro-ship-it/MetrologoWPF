<ui:FluentWindow x:Class="Metrologo.Views.ConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:converters="clr-namespace:Metrologo.Converters"
        Title="Configuration de la Mesure"
        Height="860" Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Icon="/Resources/logo.ico">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <!-- Template d'un réglage dynamique : Radio, ComboBox ou TextBox selon le type -->

        <DataTemplate x:Key="ReglageTemplate">
            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="{Binding Nom}"
                           Style="{StaticResource FormLabelStyle}"/>

                <!-- Binaire (2 options) : deux RadioButtons -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding EstBinaire, Converter={StaticResource BoolToVis}}">
                    <RadioButton Content="{Binding LibellePremiereOption}"
                                 IsChecked="{Binding EstPremiereOption, Mode=TwoWay}"
                                 GroupName="{Binding GroupeRadio}"
                                 FontWeight="SemiBold"
                                 Margin="0,0,20,0"/>
                    <RadioButton Content="{Binding LibelleSecondeOption}"
                                 IsChecked="{Binding EstSecondeOption, Mode=TwoWay}"
                                 GroupName="{Binding GroupeRadio}"
                                 FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Choix 3+ options : RadioButtons, même rendu que le binaire (ListBox invisible
                     pour garder SelectedItem lié à OptionSelectionnee) -->
                <ListBox ItemsSource="{Binding Options}"
                         SelectedItem="{Binding OptionSelectionnee, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         Visibility="{Binding EstChoixMultiple, Converter={StaticResource BoolToVis}}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <RadioButton Content="{Binding Libelle}"
                                                     IsChecked="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                     GroupName="{Binding DataContext.GroupeRadio, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                     FontWeight="SemiBold"
                                                     Margin="0,0,0,6"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Numerique (Trigger) : TextBox + unité -->
                <Grid Visibility="{Binding EstNumerique, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0"
                                Text="{Binding Valeur, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="0 par défaut — tape une valeur (ex: 0,5)"
                                ToolTip="Niveau de déclenchement en volts. Vide ou 0 = trigger à 0 V (centre du signal pour une sinusoïde centrée)."
                                Padding="10,6"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Unite}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                </Grid>
            </StackPanel>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Configuration de la mesure" ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/logo.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- En-tête -->
        <Border Grid.Row="1" Padding="24,12,24,16"
                Background="{DynamicResource ApplicationBackgroundBrush}">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10"
                        Background="{StaticResource AsertiNavyBrush}"
                        Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="Settings24" FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Paramètres de mesure"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="Configurez la fiche d'intervention et les réglages instrument"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,0,24,16">
            <StackPanel>

                <!-- Section : Identification -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="DocumentText24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Identification" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <TextBlock Text="N° FICHE D'INTERVENTION" Style="{StaticResource FormLabelStyle}"/>
                        <ui:TextBox x:Name="TbNumFI"
                                    Text="{Binding MesureConfig.NumFI, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Ex: F6_03994"
                                    MaxLength="8"
                                    Padding="10,8"
                                    FontFamily="Cascadia Mono, Consolas"
                                    TextChanged="OnNumFITextChanged"/>
                        <TextBlock Text="Format : 2 caractères + _ + 5 chiffres (le _ est ajouté automatiquement)"
                                   FontSize="10" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </Border>

                <!-- Section : Type de mesure (visible une fois le N° FI valide) -->
                <Border Style="{StaticResource FormSectionStyle}"
                        Visibility="{Binding EtapeFIValide, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="DataHistogram24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Type de mesure" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <ListBox ItemsSource="{Binding TypesMesure}"
                                 SelectedItem="{Binding MesureConfig.TypeMesure}"
                                 SelectionChanged="TypeMesure_SelectionChanged"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Margin="0,0,0,14">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="3"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="b"
                                                        CornerRadius="6"
                                                        Padding="10,8"
                                                        Background="White"
                                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                        BorderThickness="1">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeLightBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="b" Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.12"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                        <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <TextBlock Text="NOMBRE DE MESURES" Style="{StaticResource FormLabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding MeasurementCounts}"
                                      SelectedItem="{Binding MesureConfig.NbMesures}"
                                      Padding="10,6"/>
                            <TextBlock Grid.Column="1" Text="Max 100"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </Grid>

                        <!-- Module d'incertitude filtré par type de mesure, message d'aide si aucun -->

                        <TextBlock Text="MODULE D'INCERTITUDE"
                                   Style="{StaticResource FormLabelStyle}"
                                   Margin="0,14,0,4"/>
                        <ComboBox ItemsSource="{Binding ModulesDisponibles}"
                                  SelectedItem="{Binding ModuleSelectionne, Mode=TwoWay}"
                                  DisplayMemberPath="LibelleAffiche"
                                  Padding="10,6"
                                  Visibility="{Binding AModulesIncertitude, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="Aucun module d'incertitude défini pour ce type de mesure — coefficients par défaut utilisés."
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Visibility="{Binding AModulesIncertitude, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                        <!-- Module fréquence auxiliaire, visible en Tachymètre : coeffs A/B (Hz) du fréquencemètre support -->

                        <StackPanel Visibility="{Binding ModuleFreqRequis, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="MODULE FRÉQUENCE (HZ — POUR COEFF A / B)"
                                       Style="{StaticResource FormLabelStyle}"
                                       Margin="0,14,0,4"/>
                            <ComboBox ItemsSource="{Binding ModulesFreqDisponibles}"
                                      SelectedItem="{Binding ModuleFreqSelectionne, Mode=TwoWay}"
                                      DisplayMemberPath="LibelleAffiche"
                                      Padding="10,6"
                                      ToolTip="Module de la catégorie Fréquence qui caractérise le fréquencemètre support du tachymètre. Alimente ZNCoeffA / ZNCoeffB du rapport."/>
                            <TextBlock Text="Sélectionne le module du fréquencemètre utilisé (Admin → catégorie Fréquence)."
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       FontStyle="Italic"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Section : Source du signal (visible uniquement pour Fréquence + étape 2 OK) -->
                <Border Style="{StaticResource FormSectionStyle}"
                        Visibility="{Binding AfficherSourceMesure, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Pulse24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Source du signal" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <TextBlock Text="Sélectionnez la nature de l'appareil sous test"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSourceFrequencemetre}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Gauge24" FontSize="18"
                                                   Foreground="{StaticResource AsertiNavyBrush}"
                                                   Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <RadioButton Content="Fréquencemètre"
                                                 IsChecked="{Binding IsSourceFrequencemetre, Mode=TwoWay}"
                                                 FontWeight="SemiBold"
                                                 VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSourceGenerateur}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Pulse24" FontSize="18"
                                                   Foreground="{StaticResource AsertiNavyBrush}"
                                                   Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <RadioButton Content="Générateur"
                                                 IsChecked="{Binding IsSourceGenerateur, Mode=TwoWay}"
                                                 FontWeight="SemiBold"
                                                 VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Section : Instrument (visible une fois Type + Module sélectionnés) -->
                <Border Style="{StaticResource FormSectionStyle}"
                        Visibility="{Binding EtapeTypeValide, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Gauge24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Instrument" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <TextBlock Text="FRÉQUENCEMÈTRE" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Appareils}"
                                  SelectedItem="{Binding AppareilSelectionne, Mode=TwoWay}"
                                  DisplayMemberPath="Libelle"
                                  SelectionChanged="ComboBox_SelectionChanged"
                                  Padding="10,6"
                                  Margin="0,0,0,14"/>
                        <TextBlock Text="Les appareils détectés sur le bus GPIB apparaissent ici automatiquement (coche verte)."
                                   FontSize="10"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14"/>

                        <!-- Adresse GPIB en mode adresses fixes (appareils legacy), lecture seule ici -->

                        <StackPanel Visibility="{Binding ModeAdressesFixes, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,14">
                            <TextBlock Text="ADRESSE GPIB" Style="{StaticResource FormLabelStyle}"/>
                            <ui:TextBox Text="{Binding AdresseFixeSaisie, Mode=OneWay}"
                                        IsReadOnly="True"
                                        Padding="10,6"/>
                            <TextBlock Text="Adresse définie dans Administration → « Adresses GPIB (fixes) ». Non modifiable ici."
                                       FontSize="10"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Paramètres de mesure (gate) -->
                        <StackPanel Visibility="{Binding ShowGateSettings, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,14">
                            <TextBlock Text="TEMPS DE PORTE (GATE)" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding GateTimes}"
                                      SelectedItem="{Binding GateLibelleSelectionne, Mode=TwoWay}"
                                      Padding="10,6"/>
                        </StackPanel>

                        <!-- Réglages instrument -->
                        <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                CornerRadius="6"
                                Padding="14"
                                Margin="0,0,0,0">
                            <StackPanel>
                                <CheckBox Content="Initialisation manuelle"
                                          IsChecked="{Binding InitManu}"
                                          IsEnabled="{Binding InitManuDisponible}"
                                          Visibility="{Binding InitManuDisponible, Converter={StaticResource BoolToVis}}"
                                          Margin="0,0,0,12"/>
                            </StackPanel>
                        </Border>

                        <!-- ====== Configuration Intervalle de temps (53230A) ======
                             Visible quand on décoche l'init manuelle en mode Intervalle : l'opérateur
                             règle la mesure ici (1 ou 2 voies), le logiciel génère et envoie le SCPI. -->
                        <StackPanel Visibility="{Binding ShowIntervalleConfig, Converter={StaticResource BoolToVis}}"
                                    Margin="0,12,0,0">

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ui:SymbolIcon Symbol="Options24" FontSize="16"
                                               Foreground="{StaticResource AsertiOrangeBrush}"
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Paramètres d'intervalle de temps"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AsertiNavyBrush}"/>
                            </StackPanel>

                            <!-- Choix 1 voie / 2 voies : pilote l'affichage et la commande CONF:TINT -->
                            <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6" Padding="14" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="MESURE SUR"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Content="1 voie"
                                                     IsChecked="{Binding IntervModeUneVoie, Mode=TwoWay}"
                                                     GroupName="IntervVoies" FontWeight="SemiBold"
                                                     Margin="0,0,24,0"/>
                                        <RadioButton Content="2 voies (1 → 2)"
                                                     IsChecked="{Binding IntervModeDeuxVoies, Mode=TwoWay}"
                                                     GroupName="IntervVoies" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ===== Bloc 1 voie : start et stop sur la voie 1 ===== -->
                            <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6" Padding="14" Margin="0,0,0,8"
                                    Visibility="{Binding ShowIntervUneVoie, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="VOIE 1"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,0,10"/>

                                    <TextBlock Text="Couplage" Style="{StaticResource FormLabelStyle}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <RadioButton Content="DC" IsChecked="{Binding IntervDc1, Mode=TwoWay}"
                                                     GroupName="ICoupU" Margin="0,0,24,0"/>
                                        <RadioButton Content="AC" IsChecked="{Binding IntervAc1, Mode=TwoWay}"
                                                     GroupName="ICoupU"/>
                                    </StackPanel>

                                    <TextBlock Text="Impédance" Style="{StaticResource FormLabelStyle}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <RadioButton Content="50 Ω" IsChecked="{Binding IntervImp50_1, Mode=TwoWay}"
                                                     GroupName="IImpU" Margin="0,0,24,0"/>
                                        <RadioButton Content="1 MΩ" IsChecked="{Binding IntervImp1M_1, Mode=TwoWay}"
                                                     GroupName="IImpU"/>
                                    </StackPanel>

                                    <TextBlock Text="DÉPART" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}" Margin="0,4,0,4"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBox Grid.Column="0"
                                                    Text="{Binding IntervSeuilStartTexte, UpdateSourceTrigger=PropertyChanged}"
                                                    PlaceholderText="Seuil de départ (ex: 1,0)"/>
                                        <TextBlock Grid.Column="1" Text="V" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <RadioButton Content="Montant" IsChecked="{Binding IntervStartMontant, Mode=TwoWay}"
                                                     GroupName="IStartU" Margin="0,0,24,0"/>
                                        <RadioButton Content="Descendant" IsChecked="{Binding IntervStartDescendant, Mode=TwoWay}"
                                                     GroupName="IStartU"/>
                                    </StackPanel>

                                    <TextBlock Text="ARRÊT" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}" Margin="0,4,0,4"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBox Grid.Column="0"
                                                    Text="{Binding IntervSeuilStopTexte, UpdateSourceTrigger=PropertyChanged}"
                                                    PlaceholderText="Seuil d'arrêt (ex: 1,0)"/>
                                        <TextBlock Grid.Column="1" Text="V" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <RadioButton Content="Montant" IsChecked="{Binding IntervStopMontant, Mode=TwoWay}"
                                                     GroupName="IStopU" Margin="0,0,24,0"/>
                                        <RadioButton Content="Descendant" IsChecked="{Binding IntervStopDescendant, Mode=TwoWay}"
                                                     GroupName="IStopU"/>
                                    </StackPanel>

                                    <!-- Hold-off : seulement utile en 1 voie (inhiber le 1er front) -->
                                    <StackPanel Visibility="{Binding ShowHoldoff, Converter={StaticResource BoolToVis}}"
                                                Margin="0,4,0,0">
                                        <TextBlock Text="Inhibition du 1er front (hold-off)"
                                                   Style="{StaticResource FormLabelStyle}"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBox Grid.Column="0"
                                                        Text="{Binding IntervHoldoffTexte, UpdateSourceTrigger=PropertyChanged}"
                                                        PlaceholderText="0 = désactivé"/>
                                            <TextBlock Grid.Column="1" Text="ns" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                        <TextBlock Text="Nécessaire pour un intervalle montant→montant sur la même voie (sinon départ et arrêt tombent sur le même front). Valeur entre 0 et une période. 0 = désactivé."
                                                   FontSize="10" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ===== Bloc 2 voies : start voie 1, stop voie 2 ===== -->
                            <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6" Padding="14" Margin="0,0,0,8"
                                    Visibility="{Binding ShowIntervDeuxVoies, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- VOIE 1 (départ) -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="VOIE 1 (départ)"
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="{StaticResource AsertiNavyBrush}" Margin="0,0,0,10"/>

                                        <TextBlock Text="Couplage" Style="{StaticResource FormLabelStyle}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <RadioButton Content="DC" IsChecked="{Binding IntervDc1, Mode=TwoWay}"
                                                         GroupName="ICoup1D" Margin="0,0,16,0"/>
                                            <RadioButton Content="AC" IsChecked="{Binding IntervAc1, Mode=TwoWay}"
                                                         GroupName="ICoup1D"/>
                                        </StackPanel>

                                        <TextBlock Text="Impédance" Style="{StaticResource FormLabelStyle}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <RadioButton Content="50 Ω" IsChecked="{Binding IntervImp50_1, Mode=TwoWay}"
                                                         GroupName="IImp1D" Margin="0,0,16,0"/>
                                            <RadioButton Content="1 MΩ" IsChecked="{Binding IntervImp1M_1, Mode=TwoWay}"
                                                         GroupName="IImp1D"/>
                                        </StackPanel>

                                        <TextBlock Text="Seuil" Style="{StaticResource FormLabelStyle}"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBox Grid.Column="0"
                                                        Text="{Binding IntervSeuilStartTexte, UpdateSourceTrigger=PropertyChanged}"
                                                        PlaceholderText="ex: 1,0"/>
                                            <TextBlock Grid.Column="1" Text="V" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                        <TextBlock Text="Pente" Style="{StaticResource FormLabelStyle}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Content="Montant" IsChecked="{Binding IntervStartMontant, Mode=TwoWay}"
                                                         GroupName="IStart2D" Margin="0,0,16,0"/>
                                            <RadioButton Content="Desc." IsChecked="{Binding IntervStartDescendant, Mode=TwoWay}"
                                                         GroupName="IStart2D"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- VOIE 2 (arrêt) -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="VOIE 2 (arrêt)"
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="{StaticResource AsertiNavyBrush}" Margin="0,0,0,10"/>

                                        <TextBlock Text="Couplage" Style="{StaticResource FormLabelStyle}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <RadioButton Content="DC" IsChecked="{Binding IntervDc2, Mode=TwoWay}"
                                                         GroupName="ICoup2D" Margin="0,0,16,0"/>
                                            <RadioButton Content="AC" IsChecked="{Binding IntervAc2, Mode=TwoWay}"
                                                         GroupName="ICoup2D"/>
                                        </StackPanel>

                                        <TextBlock Text="Impédance" Style="{StaticResource FormLabelStyle}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <RadioButton Content="50 Ω" IsChecked="{Binding IntervImp50_2, Mode=TwoWay}"
                                                         GroupName="IImp2D" Margin="0,0,16,0"/>
                                            <RadioButton Content="1 MΩ" IsChecked="{Binding IntervImp1M_2, Mode=TwoWay}"
                                                         GroupName="IImp2D"/>
                                        </StackPanel>

                                        <TextBlock Text="Seuil" Style="{StaticResource FormLabelStyle}"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBox Grid.Column="0"
                                                        Text="{Binding IntervSeuilStopTexte, UpdateSourceTrigger=PropertyChanged}"
                                                        PlaceholderText="ex: 1,0"/>
                                            <TextBlock Grid.Column="1" Text="V" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                        <TextBlock Text="Pente" Style="{StaticResource FormLabelStyle}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Content="Montant" IsChecked="{Binding IntervStopMontant, Mode=TwoWay}"
                                                         GroupName="IStop2D" Margin="0,0,16,0"/>
                                            <RadioButton Content="Desc." IsChecked="{Binding IntervStopDescendant, Mode=TwoWay}"
                                                         GroupName="IStop2D"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Réglages dynamiques du catalogue, regroupés par voie et par mode -->

                        <StackPanel Visibility="{Binding ShowReglagesDynamiques, Converter={StaticResource BoolToVis}}"
                                    Margin="0,12,0,0">

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ui:SymbolIcon Symbol="Options24" FontSize="16"
                                               Foreground="{StaticResource AsertiOrangeBrush}"
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Réglages spécifiques à l'appareil"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AsertiNavyBrush}"/>
                            </StackPanel>

                            <!-- Voie active : seuls les réglages de la voie choisie sont envoyés à l'appareil -->

                            <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6"
                                    Padding="14"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="VOIE ACTIVE"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="Choisis la voie sur laquelle la mesure sera effectuée. Seuls ses réglages seront envoyés à l'appareil."
                                               FontSize="10"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Content="Voie A"
                                                     IsChecked="{Binding EstVoieA, Mode=TwoWay}"
                                                     IsEnabled="{Binding AReglagesVoieA}"
                                                     GroupName="VoieActive"
                                                     FontWeight="SemiBold"
                                                     Margin="0,0,24,0"/>
                                        <RadioButton Content="Voie B"
                                                     IsChecked="{Binding EstVoieB, Mode=TwoWay}"
                                                     IsEnabled="{Binding AReglagesVoieB}"
                                                     GroupName="VoieActive"
                                                     FontWeight="SemiBold"
                                                     Margin="0,0,24,0"/>
                                        <RadioButton Content="Voie C"
                                                     IsChecked="{Binding EstVoieC, Mode=TwoWay}"
                                                     IsEnabled="{Binding AReglagesVoieC}"
                                                     GroupName="VoieActive"
                                                     FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Voie A, visible si active -->
                            <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6"
                                    Padding="14"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding AfficherVoieA, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="VOIE A"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding ReglagesVoieA}"
                                                  ItemTemplate="{StaticResource ReglageTemplate}"/>
                                </StackPanel>
                            </Border>

                            <!-- Voie B, visible si active -->
                            <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6"
                                    Padding="14"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding AfficherVoieB, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="VOIE B"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding ReglagesVoieB}"
                                                  ItemTemplate="{StaticResource ReglageTemplate}"/>
                                </StackPanel>
                            </Border>

                            <!-- Voie C, visible si active -->
                            <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6"
                                    Padding="14"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding AfficherVoieC, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="VOIE C"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding ReglagesVoieC}"
                                                  ItemTemplate="{StaticResource ReglageTemplate}"/>
                                </StackPanel>
                            </Border>

                            <!-- Mode de mesure -->
                            <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6"
                                    Padding="14"
                                    Margin="0,0,0,0"
                                    Visibility="{Binding AReglagesMode, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="MODE DE MESURE"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding ReglagesMode}"
                                                  ItemTemplate="{StaticResource ReglageTemplate}"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Section : Mode de calcul (visible une fois Type + Module sélectionnés) -->
                <Border Style="{StaticResource FormSectionStyle}"
                        Visibility="{Binding EtapeTypeValide, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Calculator24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Mode de calcul" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsModeDirect}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <RadioButton Content="Direct"
                                             IsChecked="{Binding IsModeDirect, Mode=TwoWay}"
                                             FontWeight="SemiBold"/>
                            </Border>

                            <Border Grid.Column="2"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsModeIndirect}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IndirectDisponible}" Value="False">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <RadioButton Content="Indirect"
                                             IsChecked="{Binding IsModeIndirect, Mode=TwoWay}"
                                             IsEnabled="{Binding IndirectDisponible}"
                                             FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IndirectDisponible}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ui:SymbolIcon Symbol="Warning24" FontSize="14"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Mode indirect non disponible en paillasse"
                                       FontSize="11"
                                       Foreground="{StaticResource AsertiOrangeDarkBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsModeIndirect, Converter={StaticResource BoolToVis}}"
                                    Margin="0,6,0,0">
                            <TextBlock Text="FRÉQUENCE NOMINALE (HZ)" Style="{StaticResource FormLabelStyle}"/>
                            <ui:TextBox Text="{Binding MesureConfig.FNominale}"
                                        PlaceholderText="Ex: 10000000"
                                        Padding="10,8"
                                        Margin="0,0,0,12"/>

                            <TextBlock Text="COEFFICIENT MULTIPLICATEUR D'ÉCART" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding CoefsMultiplicateurs}"
                                      SelectedIndex="{Binding MesureConfig.IndexMultiplicateur}"
                                      Padding="10,6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Barre de boutons -->
        <Border Grid.Row="3"
                Padding="24,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Annuler"
                        Command="{Binding AnnulerCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>

                <Button Grid.Column="2"
                        Content="Valider la configuration"
                        Command="{Binding ValiderCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
