<Window x:Class="Metrologo.Views.ConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuration de la Mesure" Height="650" Width="450" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        xmlns:converters="clr-namespace:Metrologo.Converters">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="N° Fiche d'Intervention" FontWeight="Bold"/>
            <TextBox Text="{Binding MesureConfig.NumFI}" MaxLength="8" Margin="0,5,0,15"/>

            <TextBlock Text="Type de Mesure" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox ItemsSource="{Binding TypesMesure}" SelectedItem="{Binding MesureConfig.TypeMesure}" SelectionChanged="TypeMesure_SelectionChanged" Margin="0,0,0,15">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Nombre de mesures :" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox ItemsSource="{Binding MeasurementCounts}" 
                  SelectedItem="{Binding MesureConfig.NbMesures}" 
                  Grid.Column="0" />

                    <TextBlock Text=" (Max 100)" 
                   VerticalAlignment="Center" 
                   Margin="10,0,0,0" 
                   Foreground="Gray" 
                   Grid.Column="1"/>
                </Grid>
            </StackPanel>

            <TextBlock Text="Instrument" FontWeight="Bold"/>
            <ComboBox ItemsSource="{Binding Appareils}" SelectedItem="{Binding MesureConfig.Frequencemetre}" SelectionChanged="ComboBox_SelectionChanged" Margin="0,5,0,15"/>

            <GroupBox Header="Paramètres de Mesure" Visibility="{Binding ShowGateSettings, Converter={StaticResource BoolToVis}}" Margin="0,0,0,15" Padding="10">
                <StackPanel>
                    <TextBlock Text="Temps de porte (Gate) :"/>
                    <ComboBox ItemsSource="{Binding GateTimes}" SelectedIndex="{Binding MesureConfig.GateIndex}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Réglages Instrument" Padding="10" Margin="0,0,0,15">
                <StackPanel>
                    <CheckBox Content="Initialisation Manuelle" IsChecked="{Binding MesureConfig.InitManu}" Margin="0,0,0,10"/>
                    <StackPanel Visibility="{Binding IsStanford, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Gamme d'entrée :"/>
                        <ComboBox ItemsSource="{Binding StanfordRanges}" SelectedIndex="{Binding MesureConfig.InputIndex}" SelectionChanged="ComboBox_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Visibility="{Binding IsRacal, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Entrée sélectionnée :"/>
                        <ComboBox ItemsSource="{Binding RacalRanges}" SelectedIndex="{Binding MesureConfig.InputIndex}" SelectionChanged="ComboBox_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Visibility="{Binding IsEip, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Bande de fréquence :"/>
                        <ComboBox ItemsSource="{Binding EipRanges}" SelectedIndex="{Binding MesureConfig.InputIndex}"/>
                    </StackPanel>
                    <StackPanel Visibility="{Binding ShowCoupling, Converter={StaticResource BoolToVis}}" Margin="0,10,0,0">
                        <TextBlock Text="Couplage :"/>
                        <ComboBox ItemsSource="{Binding Couplings}" SelectedIndex="{Binding MesureConfig.CouplingIndex}"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Mode de calcul" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <RadioButton Content="Direct"
                     IsChecked="{Binding IsModeDirect, Mode=TwoWay}" />
                    <RadioButton Content="Indirect"
                     IsChecked="{Binding IsModeIndirect, Mode=TwoWay}"
                     IsEnabled="{Binding IndirectDisponible}"
                     Margin="0,5,0,0"/>
                    <TextBlock Text="⚠️ Mode indirect non disponible en paillasse"
                   Foreground="OrangeRed" FontSize="11" Margin="0,4,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IndirectDisponible}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <StackPanel Visibility="{Binding IsModeIndirect,
                        Converter={StaticResource BoolToVis}}" Margin="20,10,0,0">
                        <TextBlock Text="Fréquence Nominale (Hz) :"/>
                        <TextBox Text="{Binding MesureConfig.FNominale}"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <UniformGrid Columns="2">
                <Button Content="Annuler" Command="{Binding AnnulerCommand}" Margin="5" Padding="5"/>
                <Button Content="Valider" Command="{Binding ValiderCommand}" Margin="5" Padding="5" Background="#0078D7" Foreground="White"/>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</Window>