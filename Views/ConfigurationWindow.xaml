<ui:FluentWindow x:Class="Metrologo.Views.ConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:converters="clr-namespace:Metrologo.Converters"
        Title="Configuration de la Mesure"
        Height="780" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <!-- DataTemplate unique pour un réglage dynamique — rendu switch entre Radio/ComboBox/TextBox
             selon EstBinaire / EstChoixMultiple / EstNumerique. -->
        <DataTemplate x:Key="ReglageTemplate">
            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="{Binding Nom}"
                           Style="{StaticResource FormLabelStyle}"/>

                <!-- Binaire (2 options) : deux RadioButtons -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding EstBinaire, Converter={StaticResource BoolToVis}}">
                    <RadioButton Content="{Binding LibellePremiereOption}"
                                 IsChecked="{Binding EstPremiereOption, Mode=TwoWay}"
                                 GroupName="{Binding GroupeRadio}"
                                 FontWeight="SemiBold"
                                 Margin="0,0,20,0"/>
                    <RadioButton Content="{Binding LibelleSecondeOption}"
                                 IsChecked="{Binding EstSecondeOption, Mode=TwoWay}"
                                 GroupName="{Binding GroupeRadio}"
                                 FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Choix 3+ options : ComboBox -->
                <ComboBox ItemsSource="{Binding Options}"
                          SelectedItem="{Binding OptionSelectionnee, Mode=TwoWay}"
                          DisplayMemberPath="Libelle"
                          Padding="10,6"
                          Visibility="{Binding EstChoixMultiple, Converter={StaticResource BoolToVis}}"/>

                <!-- Numerique (Trigger) : TextBox + unité -->
                <Grid Visibility="{Binding EstNumerique, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0"
                                Text="{Binding Valeur, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Laisser vide si non utilisé"
                                Padding="10,6"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Unite}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                </Grid>
            </StackPanel>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Configuration de la mesure" ShowMaximize="False"/>

        <!-- En-tête -->
        <Border Grid.Row="1" Padding="24,12,24,16"
                Background="{DynamicResource ApplicationBackgroundBrush}">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10"
                        Background="{StaticResource AsertiNavyBrush}"
                        Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="Settings24" FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Paramètres de mesure"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="Configurez la fiche d'intervention et les réglages instrument"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,0,24,16">
            <StackPanel>

                <!-- Section : Identification -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="DocumentText24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Identification" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <TextBlock Text="N° FICHE D'INTERVENTION" Style="{StaticResource FormLabelStyle}"/>
                        <ui:TextBox Text="{Binding MesureConfig.NumFI}"
                                    PlaceholderText="Ex: D0123456"
                                    MaxLength="8"
                                    Padding="10,8"/>
                    </StackPanel>
                </Border>

                <!-- Section : Type de mesure -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="DataHistogram24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Type de mesure" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <ListBox ItemsSource="{Binding TypesMesure}"
                                 SelectedItem="{Binding MesureConfig.TypeMesure}"
                                 SelectionChanged="TypeMesure_SelectionChanged"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Margin="0,0,0,14">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="3"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="b"
                                                        CornerRadius="6"
                                                        Padding="10,8"
                                                        Background="White"
                                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                        BorderThickness="1">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeLightBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="b" Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.12"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                        <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <TextBlock Text="NOMBRE DE MESURES" Style="{StaticResource FormLabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding MeasurementCounts}"
                                      SelectedItem="{Binding MesureConfig.NbMesures}"
                                      Padding="10,6"/>
                            <TextBlock Grid.Column="1" Text="Max 100"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Section : Source du signal (visible uniquement pour Fréquence) -->
                <Border Style="{StaticResource FormSectionStyle}"
                        Visibility="{Binding ShowSourceMesure, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Pulse24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Source du signal" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <TextBlock Text="Sélectionnez la nature de l'appareil sous test"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSourceFrequencemetre}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Gauge24" FontSize="18"
                                                   Foreground="{StaticResource AsertiNavyBrush}"
                                                   Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <RadioButton Content="Fréquencemètre"
                                                 IsChecked="{Binding IsSourceFrequencemetre, Mode=TwoWay}"
                                                 FontWeight="SemiBold"
                                                 VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSourceGenerateur}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Pulse24" FontSize="18"
                                                   Foreground="{StaticResource AsertiNavyBrush}"
                                                   Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <RadioButton Content="Générateur"
                                                 IsChecked="{Binding IsSourceGenerateur, Mode=TwoWay}"
                                                 FontWeight="SemiBold"
                                                 VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Section : Instrument -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Gauge24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Instrument" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <TextBlock Text="FRÉQUENCEMÈTRE" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Appareils}"
                                  SelectedItem="{Binding AppareilSelectionne, Mode=TwoWay}"
                                  DisplayMemberPath="Libelle"
                                  SelectionChanged="ComboBox_SelectionChanged"
                                  Padding="10,6"
                                  Margin="0,0,0,14"/>
                        <TextBlock Text="Les appareils détectés sur le bus GPIB apparaissent ici automatiquement (coche verte)."
                                   FontSize="10"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14"/>

                        <!-- Paramètres de mesure (gate) -->
                        <StackPanel Visibility="{Binding ShowGateSettings, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,14">
                            <TextBlock Text="TEMPS DE PORTE (GATE)" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding GateTimes}"
                                      SelectedItem="{Binding GateLibelleSelectionne, Mode=TwoWay}"
                                      Padding="10,6"/>
                        </StackPanel>

                        <!-- Réglages instrument -->
                        <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                CornerRadius="6"
                                Padding="14"
                                Margin="0,0,0,0">
                            <StackPanel>
                                <CheckBox Content="Initialisation manuelle"
                                          IsChecked="{Binding MesureConfig.InitManu}"
                                          IsEnabled="{Binding InitManuDisponible}"
                                          Visibility="{Binding InitManuDisponible, Converter={StaticResource BoolToVis}}"
                                          Margin="0,0,0,12"/>
                            </StackPanel>
                        </Border>

                        <!-- Réglages dynamiques définis dans le catalogue : regroupés par voie + mode
                             pour un rendu structuré. RadioButtons pour les choix binaires, ComboBox sinon. -->
                        <StackPanel Visibility="{Binding AReglagesDynamiques, Converter={StaticResource BoolToVis}}"
                                    Margin="0,12,0,0">

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ui:SymbolIcon Symbol="Options24" FontSize="16"
                                               Foreground="{StaticResource AsertiOrangeBrush}"
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Réglages spécifiques à l'appareil"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AsertiNavyBrush}"/>
                            </StackPanel>

                            <!-- Sélection de la voie active : seuls les réglages de la voie choisie
                                 seront envoyés à l'appareil. Évite de modifier une voie non utilisée. -->
                            <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6"
                                    Padding="14"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="VOIE ACTIVE"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="Choisis la voie sur laquelle la mesure sera effectuée. Seuls ses réglages seront envoyés à l'appareil."
                                               FontSize="10"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Content="Voie A"
                                                     IsChecked="{Binding EstVoieA, Mode=TwoWay}"
                                                     IsEnabled="{Binding AReglagesVoieA}"
                                                     GroupName="VoieActive"
                                                     FontWeight="SemiBold"
                                                     Margin="0,0,24,0"/>
                                        <RadioButton Content="Voie B"
                                                     IsChecked="{Binding EstVoieB, Mode=TwoWay}"
                                                     IsEnabled="{Binding AReglagesVoieB}"
                                                     GroupName="VoieActive"
                                                     FontWeight="SemiBold"
                                                     Margin="0,0,24,0"/>
                                        <RadioButton Content="Voie C"
                                                     IsChecked="{Binding EstVoieC, Mode=TwoWay}"
                                                     IsEnabled="{Binding AReglagesVoieC}"
                                                     GroupName="VoieActive"
                                                     FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Voie A - visible uniquement si la voie A est active -->
                            <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6"
                                    Padding="14"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding AfficherVoieA, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="VOIE A"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding ReglagesVoieA}"
                                                  ItemTemplate="{StaticResource ReglageTemplate}"/>
                                </StackPanel>
                            </Border>

                            <!-- Voie B - visible uniquement si la voie B est active -->
                            <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6"
                                    Padding="14"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding AfficherVoieB, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="VOIE B"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding ReglagesVoieB}"
                                                  ItemTemplate="{StaticResource ReglageTemplate}"/>
                                </StackPanel>
                            </Border>

                            <!-- Voie C - visible uniquement si la voie C est active -->
                            <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6"
                                    Padding="14"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding AfficherVoieC, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="VOIE C"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding ReglagesVoieC}"
                                                  ItemTemplate="{StaticResource ReglageTemplate}"/>
                                </StackPanel>
                            </Border>

                            <!-- Mode de mesure -->
                            <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                    CornerRadius="6"
                                    Padding="14"
                                    Margin="0,0,0,0"
                                    Visibility="{Binding AReglagesMode, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="MODE DE MESURE"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding ReglagesMode}"
                                                  ItemTemplate="{StaticResource ReglageTemplate}"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Section : Mode de calcul -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Calculator24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Mode de calcul" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsModeDirect}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <RadioButton Content="Direct"
                                             IsChecked="{Binding IsModeDirect, Mode=TwoWay}"
                                             FontWeight="SemiBold"/>
                            </Border>

                            <Border Grid.Column="2"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsModeIndirect}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IndirectDisponible}" Value="False">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <RadioButton Content="Indirect"
                                             IsChecked="{Binding IsModeIndirect, Mode=TwoWay}"
                                             IsEnabled="{Binding IndirectDisponible}"
                                             FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IndirectDisponible}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ui:SymbolIcon Symbol="Warning24" FontSize="14"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Mode indirect non disponible en paillasse"
                                       FontSize="11"
                                       Foreground="{StaticResource AsertiOrangeDarkBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsModeIndirect, Converter={StaticResource BoolToVis}}"
                                    Margin="0,6,0,0">
                            <TextBlock Text="FRÉQUENCE NOMINALE (HZ)" Style="{StaticResource FormLabelStyle}"/>
                            <ui:TextBox Text="{Binding MesureConfig.FNominale}"
                                        PlaceholderText="Ex: 10000000"
                                        Padding="10,8"
                                        Margin="0,0,0,12"/>

                            <TextBlock Text="COEFFICIENT MULTIPLICATEUR D'ÉCART" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding CoefsMultiplicateurs}"
                                      SelectedIndex="{Binding MesureConfig.IndexMultiplicateur}"
                                      Padding="10,6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Barre de boutons -->
        <Border Grid.Row="3"
                Padding="24,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Annuler"
                        Command="{Binding AnnulerCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>

                <Button Grid.Column="2"
                        Content="Valider la configuration"
                        Command="{Binding ValiderCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
