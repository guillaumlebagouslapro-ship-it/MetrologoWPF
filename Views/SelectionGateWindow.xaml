<ui:FluentWindow x:Class="Metrologo.Views.SelectionGateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Sélection du temps de porte"
        Height="680" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Sélection du temps de porte" ShowMaximize="False"/>

        <Border Grid.Row="1" Padding="24,12,24,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10"
                        Background="{StaticResource AsertiNavyBrush}"
                        Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="Timer24" FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Titre}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="{Binding SousTitre}"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,0,24,16">
            <StackPanel>

                <!-- Mode "Gate fixe" : visible sauf en Stabilité -->
                <Border Style="{StaticResource FormSectionStyle}"
                        Visibility="{Binding IsStabilite, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Timer24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Temps de porte" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <TextBlock Text="Durée d'intégration d'une mesure individuelle"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,10"/>

                        <ComboBox ItemsSource="{Binding GatesDisponibles}"
                                  DisplayMemberPath="Libelle"
                                  SelectedIndex="{Binding GateSelectionneIndex, Mode=TwoWay}"
                                  Padding="10,8"/>
                    </StackPanel>
                </Border>

                <!-- Mode "Stabilité" : presets + cases à cocher -->
                <Border Style="{StaticResource FormSectionStyle}"
                        Visibility="{Binding IsStabilite, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Bookmark24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Preset de balayage" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <TextBlock Text="Charge un balayage prédéfini, puis ajuste les cases cochées si besoin"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding Presets}"
                                      DisplayMemberPath="Nom"
                                      SelectedItem="{Binding PresetSelectionne, Mode=TwoWay}"
                                      Padding="10,8"/>
                            <Button Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Content="Supprimer"
                                    Command="{Binding SupprimerPresetCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </Grid>

                        <Separator Margin="0,4,0,12"/>

                        <TextBlock Text="Temps de porte à balayer (cocher 1 ou plusieurs)"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <ItemsControl ItemsSource="{Binding GatesDisponibles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Libelle}"
                                              IsChecked="{Binding EstCoche, Mode=TwoWay}"
                                              MinWidth="86"
                                              Margin="0,4,12,4"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,12,0,12"/>

                        <TextBlock Text="Sauver la sélection actuelle comme nouveau preset"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding NomNouveauPreset, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Nom du preset (ex: Mon balayage rapide)"
                                        Padding="10,8"/>
                            <Button Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Content="Sauver"
                                    Command="{Binding SauverCommePresetCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Message d'erreur -->
                <Border CornerRadius="6" Padding="12,10"
                        Background="#FFFEE2E2"
                        BorderBrush="#FFFCA5A5"
                        BorderThickness="1"
                        Margin="0,0,0,6"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Warning24" FontSize="16"
                                       Foreground="#FFDC2626"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding MessageErreur}"
                                   Foreground="#FF7F1D1D"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3"
                Padding="24,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Annuler"
                        Command="{Binding AnnulerCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>

                <Button Grid.Column="2"
                        Content="Valider"
                        Command="{Binding ValiderCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
