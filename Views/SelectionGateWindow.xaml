<ui:FluentWindow x:Class="Metrologo.Views.SelectionGateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Sélection du temps de porte"
        Height="560" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Sélection du temps de porte" ShowMaximize="False"/>

        <Border Grid.Row="1" Padding="24,12,24,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10"
                        Background="{StaticResource AsertiNavyBrush}"
                        Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="Timer24" FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Titre}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="Définissez le temps de porte ou la procédure automatique"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,0,24,16">
            <StackPanel>

                <!-- Temps de porte fixe -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Timer24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Temps de porte fixe" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <TextBlock Text="Durée d'intégration d'une mesure individuelle"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,10"/>

                        <ComboBox ItemsSource="{Binding GateTimes}"
                                  SelectedIndex="{Binding GateSelectionneIndex, Mode=TwoWay}"
                                  Padding="10,8"/>
                    </StackPanel>
                </Border>

                <!-- Procédure automatique non-EIP -->
                <Border Style="{StaticResource FormSectionStyle}"
                        Visibility="{Binding AfficheProceduresStandard, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Procédure automatique" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <TextBlock Text="Balaie automatiquement plusieurs temps de porte pour une mesure de stabilité complète"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,12"/>

                        <RadioButton GroupName="Procedure"
                                     IsChecked="{Binding Procedure100SChoisie, Mode=TwoWay}"
                                     Margin="0,0,0,8">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="b" CornerRadius="6" Padding="14,12"
                                            Background="White"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Procédure Auto 1" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AsertiNavyBrush}"/>
                                            <TextBlock Text="Balayage 10 ms → 100 s"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                            <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                                            <Setter TargetName="b" Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>

                        <RadioButton GroupName="Procedure"
                                     IsChecked="{Binding Procedure10SChoisie, Mode=TwoWay}">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="b" CornerRadius="6" Padding="14,12"
                                            Background="White"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Procédure Auto 2" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AsertiNavyBrush}"/>
                                            <TextBlock Text="Balayage 10 ms → 10 s (plus rapide)"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                            <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                                            <Setter TargetName="b" Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <!-- Procédure EIP -->
                <Border Style="{StaticResource FormSectionStyle}"
                        Visibility="{Binding AfficheProcedureEip, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Procédure automatique EIP 545" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <RadioButton GroupName="ProcedureEip"
                                     IsChecked="{Binding ProcedureEipChoisie, Mode=TwoWay}">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="b" CornerRadius="6" Padding="14,12"
                                            Background="White"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Balayage EIP" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AsertiNavyBrush}"/>
                                            <TextBlock Text="3 paliers : 10 ms, 100 ms et 1 s"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                            <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                                            <Setter TargetName="b" Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <!-- Message d'erreur -->
                <Border CornerRadius="6" Padding="12,10"
                        Background="#FFFEE2E2"
                        BorderBrush="#FFFCA5A5"
                        BorderThickness="1"
                        Margin="0,0,0,6"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Warning24" FontSize="16"
                                       Foreground="#FFDC2626"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding MessageErreur}"
                                   Foreground="#FF7F1D1D"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3"
                Padding="24,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Annuler"
                        Command="{Binding AnnulerCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>

                <Button Grid.Column="2"
                        Content="Valider"
                        Command="{Binding ValiderCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
