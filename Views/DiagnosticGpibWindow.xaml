<ui:FluentWindow x:Class="Metrologo.Views.DiagnosticGpibWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Diagnostic GPIB"
        Height="640" Width="900"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre bar -->
        <ui:TitleBar Grid.Row="0" Title="Diagnostic GPIB — Scanner le bus IEEE-488"/>

        <!-- Bandeau d'intro -->
        <Border Grid.Row="1"
                CornerRadius="10"
                Padding="20,16"
                Margin="20,16,20,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock Text="DIAGNOSTIC BUS GPIB" FontSize="11" FontWeight="Bold"
                           Margin="0,0,0,4">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="{StaticResource AsertiOrangeLightColor}"/>
                    </TextBlock.Foreground>
                </TextBlock>
                <TextBlock Text="Scanner les appareils connectés"
                           FontSize="20" FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="Balaie les adresses GPIB 1 à 30 et interroge chaque appareil qui répond via *IDN?."
                           FontSize="12" Margin="0,4,0,0">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="White" Opacity="0.78"/>
                    </TextBlock.Foreground>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Barre d'action + statut -->
        <Border Grid.Row="2"
                CornerRadius="8"
                Padding="16,12"
                Margin="20,0,20,12"
                Background="White"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Command="{Binding ScannerCommand}"
                            IsEnabled="{Binding PeutScanner}"
                            Padding="18,10"
                            Background="{StaticResource AsertiOrangeBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            MinWidth="170">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Search24" FontSize="16" Foreground="White"
                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Scanner le bus" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ListerRessourcesVisaCommand}"
                            IsEnabled="{Binding PeutScanner}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="14,8"
                            Margin="8,0,0,0"
                            MinWidth="180">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="List24" FontSize="14"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Lister ressources VISA" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Statut}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <ProgressBar IsIndeterminate="True"
                                 Height="4"
                                 Margin="0,6,0,0"
                                 Visibility="{Binding ScanEnCours, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <Border Grid.Column="2" CornerRadius="20" Padding="14,8"
                        Background="#FFDCFCE7"
                        VerticalAlignment="Center">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#FF16A34A">
                        <Run Text="{Binding NbAppareilsDetectes, Mode=OneWay}"/>
                        <Run Text=" appareil(s)"/>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <!-- Message d'erreur éventuel -->
        <Border Grid.Row="2"
                CornerRadius="8"
                Padding="16,12"
                Margin="20,56,20,12"
                Background="#FFFEE2E2"
                BorderBrush="#FFFCA5A5"
                BorderThickness="1"
                VerticalAlignment="Top"
                Visibility="{Binding AErreur, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning24" FontSize="18" Foreground="#FFDC2626"
                               Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding MessageErreur}"
                           TextWrapping="Wrap" Foreground="#FF7F1D1D"
                           VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Liste des résultats -->
        <Border Grid.Row="3"
                CornerRadius="10"
                Padding="0"
                Margin="20,0,20,12"
                Background="White"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Ressources VISA listées par NI (affiché à la demande) -->
                    <Border CornerRadius="6" Padding="12,10" Margin="12,12,12,0"
                            Background="#FFE0E7FF" BorderBrush="#FF818CF8" BorderThickness="1"
                            Visibility="{Binding RessourcesVisaAffiche, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="RESSOURCES VISA DÉTECTÉES PAR NI" FontSize="10" FontWeight="Bold"
                                       Foreground="#FF4338CA" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding RessourcesVisa}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="11"
                                       Foreground="{StaticResource AsertiNavyDarkBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Resultats}" Padding="12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,4"
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FFF9FAFB"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Repond}" Value="True">
                                                <Setter Property="Background" Value="#FFDCFCE7"/>
                                                <Setter Property="BorderBrush" Value="#FF86EFAC"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="100" Padding="0,0,8,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AdresseCourte}"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="{StaticResource AsertiNavyBrush}"/>
                                    </Border>

                                    <ui:SymbolIcon Grid.Column="1" FontSize="18"
                                                   Margin="0,0,12,0" VerticalAlignment="Center">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Setter Property="Symbol" Value="Subtract24"/>
                                                <Setter Property="Foreground" Value="#FF9CA3AF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Repond}" Value="True">
                                                        <Setter Property="Symbol" Value="CheckmarkCircle24"/>
                                                        <Setter Property="Foreground" Value="#FF16A34A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AsertiNavyBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Pas de réponse"/>
                                                    <Setter Property="Foreground" Value="#FF9CA3AF"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Repond}" Value="True">
                                                            <Setter Property="Text" Value="{Binding Modele}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource AsertiNavyBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Fabricant}" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Visibility="{Binding Repond, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding ReponseIdn}" FontSize="10"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   Margin="0,2,0,0"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Visibility="{Binding Repond, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding Erreur}" FontSize="10"
                                                   Margin="0,2,0,0"
                                                   Foreground="#FFD97706"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding AErreur, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>

                                    <!-- Action au bout de la ligne : bouton Enregistrer si hors catalogue, badge sinon -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="12,0,0,0">
                                        <Border CornerRadius="12" Padding="10,4"
                                                Background="#FFDBEAFE" BorderBrush="#FF93C5FD" BorderThickness="1"
                                                Visibility="{Binding EstEnregistre, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="14"
                                                               Foreground="#FF1D4ED8"
                                                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Reconnu" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="#FF1D4ED8" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <Button Command="{Binding DataContext.EnregistrerAppareilCommand,
                                                         RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Padding="10,5"
                                                MinWidth="0"
                                                Visibility="{Binding PeutEtreEnregistre, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Add24" FontSize="12"
                                                               Foreground="White"
                                                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Enregistrer" FontSize="11"
                                                           Foreground="White" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Barre de fermeture -->
        <Border Grid.Row="4"
                Background="White"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Button Command="{Binding FermerCommand}"
                    HorizontalAlignment="Right"
                    Padding="20,8"
                    MinWidth="100">
                <TextBlock Text="Fermer"/>
            </Button>
        </Border>
    </Grid>
</ui:FluentWindow>
