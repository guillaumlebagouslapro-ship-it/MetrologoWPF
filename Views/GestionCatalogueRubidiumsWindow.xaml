<ui:FluentWindow x:Class="Metrologo.Views.GestionCatalogueRubidiumsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Catalogue des rubidiums"
        Height="600" Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Icon="/Resources/logo.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Catalogue des rubidiums" ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/logo.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Bandeau -->
        <Border Grid.Row="1" CornerRadius="10" Padding="20,16" Margin="20,16,20,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="ZONE ADMINISTRATEUR" FontSize="11" FontWeight="Bold"
                               Margin="0,0,0,4">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{StaticResource AsertiOrangeLightColor}"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Gestion du catalogue des rubidiums"
                               FontSize="20" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Ajouter, renommer ou supprimer les références de fréquence."
                               FontSize="12" Margin="0,4,0,0">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="White" Opacity="0.78"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="1"
                        Command="{Binding AjouterCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        VerticalAlignment="Center"
                        Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Add24" FontSize="14"
                                       Foreground="White"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Ajouter une référence"
                                   Foreground="White" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Liste éditable -->
        <Border Grid.Row="2" CornerRadius="10" Padding="0" Margin="20,0,20,12"
                Background="White"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid>
                <!-- État vide -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding CatalogueVide, Converter={StaticResource BoolToVis}}">
                    <ui:SymbolIcon Symbol="Timer24" FontSize="48"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Aucune référence dans le catalogue"
                               FontSize="15" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="Clique sur « Ajouter une référence » pour démarrer."
                               FontSize="12" Margin="0,6,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Rubidiums}" Padding="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                                        Background="White"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="36" Height="36" CornerRadius="10"
                                                Background="#FFDCFCE7"
                                                Margin="0,0,12,0">
                                            <ui:SymbolIcon Symbol="Timer24" FontSize="18"
                                                           Foreground="#FF16A34A"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="DÉSIGNATION" FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource AsertiOrangeBrush}"
                                                       Margin="0,0,0,2"/>
                                            <ui:TextBox Text="{Binding Designation, UpdateSourceTrigger=PropertyChanged}"
                                                        Padding="8,6"
                                                        FontWeight="SemiBold"
                                                        FontSize="13"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                            <TextBlock Text="FRÉQUENCE MOYENNE (Hz)" FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource AsertiOrangeBrush}"
                                                       Margin="0,0,0,2"/>
                                            <ui:TextBox Text="{Binding FrequenceMoyenne, UpdateSourceTrigger=LostFocus, StringFormat=N2}"
                                                        Padding="8,6"
                                                        FontFamily="Cascadia Mono, Consolas"
                                                        FontSize="13"/>
                                        </StackPanel>

                                        <Button Grid.Column="5"
                                                Command="{Binding DataContext.SupprimerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                VerticalAlignment="Center"
                                                Padding="10,8"
                                                ToolTip="Supprimer cette référence du catalogue">
                                            <ui:SymbolIcon Symbol="Delete24" FontSize="14"
                                                           Foreground="#FFDC2626"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Barre de boutons -->
        <Border Grid.Row="3"
                Padding="20,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Annuler"
                        Command="{Binding AnnulerCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>

                <Button Grid.Column="2"
                        Content="Enregistrer le catalogue"
                        Command="{Binding EnregistrerCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
