<UserControl x:Class="Metrologo.Views.SelectionPosteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F5F5F5">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="500">

            <TextBlock Text="Où vous trouvez-vous ?"
                       FontSize="26" FontWeight="Bold"
                       TextAlignment="Center" Margin="0,0,0,8"/>

            <TextBlock Text="Votre choix détermine les méthodes de mesure disponibles."
                       FontSize="13" Foreground="#666"
                       TextAlignment="Center" Margin="0,0,0,35"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Baie de mesure -->
                <Button Grid.Column="0"
                        Command="{Binding ChoisirBaieCommand}"
                        Padding="20,25"
                        Background="White"
                        BorderBrush="#0078D7"
                        BorderThickness="2"
                        Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="🖥️" FontSize="42" TextAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Baie de mesure"
                                   FontSize="16" FontWeight="SemiBold"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Toutes les méthodes disponibles"
                                   FontSize="11" Foreground="#888"
                                   TextAlignment="Center" Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>

                <!-- Paillasse -->
                <Button Grid.Column="2"
                        Command="{Binding ChoisirPaillasseCommand}"
                        Padding="20,25"
                        Background="White"
                        BorderBrush="#FF8C00"
                        BorderThickness="2"
                        Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="🔬" FontSize="42" TextAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Paillasse"
                                   FontSize="16" FontWeight="SemiBold"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Mesure indirecte désactivée"
                                   FontSize="11" Foreground="#888"
                                   TextAlignment="Center" Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>