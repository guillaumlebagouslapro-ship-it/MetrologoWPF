<ui:FluentWindow x:Class="Metrologo.Views.PremierDemarrageCheminLocalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Configuration initiale"
        Height="430" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Topmost="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Configuration initiale" ShowMaximize="False" ShowMinimize="False"/>

        <Border Grid.Row="1" Padding="24,12,24,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10"
                        Background="{StaticResource AsertiOrangeBrush}"
                        Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="Save24" FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Sauvegarde locale des rapports" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="Premier démarrage — configure le chemin local"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Padding="24,0,24,16">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,12">
                    <Run Text="Pour garantir la disponibilité de tes rapports Excel même en cas de coupure réseau avec le serveur principal, Metrologo duplique chaque mesure dans un dossier "/>
                    <Run FontWeight="Bold" Text="local"/>
                    <Run Text=" sur ce poste."/>
                </TextBlock>

                <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,14"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <Run Text="Choisis un dossier accessible en écriture sur le disque local du poste, par ex. "/>
                    <Run FontFamily="Cascadia Mono, Consolas" Text="C:\Metrologo_Backup"/>
                    <Run Text=". Tu pourras le modifier ensuite via Admin → Chemins de stockage."/>
                </TextBlock>

                <TextBlock Text="DOSSIER LOCAL DE SAUVEGARDE" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" x:Name="TbChemin"
                                PlaceholderText="C:\Metrologo_Backup"
                                FontFamily="Cascadia Mono, Consolas"
                                Padding="10,8"/>
                    <Button Grid.Column="1" Content="Parcourir..."
                            Click="OnParcourir"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="8,0,0,0" Padding="14,8"/>
                </Grid>

                <Border CornerRadius="6" Padding="12,10" Margin="0,14,0,0"
                        Background="#FFFEF3C7" BorderBrush="#FFFCD34D" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Info24" FontSize="14"
                                       Foreground="#FF92400E"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Si tu cliques « Plus tard », un bandeau d'alerte restera visible jusqu'à la configuration."
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="#FF7C2D12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Padding="24,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Plus tard" Click="OnReporter"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Column="2" Content="Enregistrer" Click="OnValider"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
