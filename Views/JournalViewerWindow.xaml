<ui:FluentWindow x:Class="Metrologo.Views.JournalViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Journal d'activité"
        Height="760" Width="1120"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <!-- Style pour les lignes d'entrée selon la sévérité -->
        <Style x:Key="EntryRowStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severite}" Value="Avertissement">
                    <Setter Property="Background" Value="#FFFFF7ED"/>
                    <Setter Property="BorderBrush" Value="#FFFED7AA"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severite}" Value="Erreur">
                    <Setter Property="Background" Value="#FFFEE2E2"/>
                    <Setter Property="BorderBrush" Value="#FFFCA5A5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Journal d'activité"/>

        <!-- En-tête -->
        <Border Grid.Row="1" Padding="24,12,24,12">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10"
                        Background="{StaticResource AsertiNavyBrush}"
                        Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="History24" FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Journal d'activité"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="Historique des actions par session utilisateur"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Barre de filtres -->
        <Border Grid.Row="2" Margin="24,0,24,12"
                Background="White"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ui:SymbolIcon Grid.Column="0" Symbol="Options24" FontSize="18"
                               Foreground="{StaticResource AsertiOrangeBrush}"
                               VerticalAlignment="Center" Margin="0,0,14,0"/>

                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="DEPUIS" Style="{StaticResource FormLabelStyle}"/>
                    <DatePicker SelectedDate="{Binding FiltreDepuis, Mode=TwoWay}" Padding="8,4"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="UTILISATEUR" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Utilisateurs}"
                              SelectedItem="{Binding FiltreUtilisateur}"
                              Padding="8,4"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,8,0">
                    <TextBlock Text="CATÉGORIE" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding CategoriesFiltre}"
                              SelectedItem="{Binding FiltreCategorie}"
                              Padding="8,4"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="0,0,8,0">
                    <TextBlock Text="SÉVÉRITÉ MIN." Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding SeveritesFiltre}"
                              SelectedItem="{Binding FiltreSeveriteMin}"
                              Padding="8,4"/>
                </StackPanel>

                <StackPanel Grid.Column="5" Margin="0,0,12,0">
                    <TextBlock Text="RECHERCHE" Style="{StaticResource FormLabelStyle}"/>
                    <ui:TextBox Text="{Binding FiltreRecherche, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="message, action…"
                                Padding="8,4">
                        <ui:TextBox.Icon>
                            <ui:SymbolIcon Symbol="Info24"/>
                        </ui:TextBox.Icon>
                    </ui:TextBox>
                </StackPanel>

                <Button Grid.Column="6"
                        Content="Appliquer"
                        Command="{Binding AppliquerFiltreCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="16,8"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- Liste des sessions -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="24,0,24,16">
            <ItemsControl ItemsSource="{Binding Sessions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Margin="0,0,0,10" IsExpanded="True">
                            <Expander.Header>
                                <Grid Width="980">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icône user -->
                                    <Border Grid.Column="0"
                                            Width="36" Height="36" CornerRadius="8"
                                            Background="{StaticResource AsertiNavyBrush}"
                                            Margin="0,0,12,0">
                                        <ui:SymbolIcon Symbol="Person24" FontSize="16"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Infos session -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Utilisateur}"
                                                       FontWeight="Bold" FontSize="14"
                                                       Foreground="{StaticResource AsertiNavyBrush}"/>
                                            <TextBlock Text=" · "
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Machine}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <Border Background="#FFDCFCE7" CornerRadius="8" Padding="6,1"
                                                    Margin="8,0,0,0"
                                                    Visibility="{Binding Active, Converter={StaticResource BoolToVis}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" Fill="#FF16A34A"
                                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="En cours" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="#FF166534"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding EnteteAffiche}"
                                                   FontSize="11"
                                                   Margin="0,2,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <!-- Badges -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="#FFE0E7FF" CornerRadius="10" Padding="8,3" Margin="4,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding NbEntrees}" FontSize="11" FontWeight="Bold" Foreground="#FF4338CA"/>
                                                <TextBlock Text=" entrées" FontSize="11" Foreground="#FF4338CA"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#FFFEF3C7" CornerRadius="10" Padding="8,3" Margin="4,0"
                                                Visibility="{Binding HasAvertissements, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⚠ " FontSize="11"/>
                                                <TextBlock Text="{Binding NbAvertissements}" FontSize="11" FontWeight="Bold" Foreground="#FF92400E"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#FFFEE2E2" CornerRadius="10" Padding="8,3" Margin="4,0"
                                                Visibility="{Binding HasErreurs, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✖ " FontSize="11"/>
                                                <TextBlock Text="{Binding NbErreurs}" FontSize="11" FontWeight="Bold" Foreground="#FF991B1B"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Expander.Header>

                            <!-- Corps : liste des entrées -->
                            <ItemsControl ItemsSource="{Binding Entrees}" Margin="46,8,0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource EntryRowStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding TimestampAffiche}"
                                                           FontFamily="Cascadia Mono, Consolas"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0"/>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding CategorieEmoji}"
                                                           FontSize="14"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0"/>

                                                <Border Grid.Column="2"
                                                        Background="#FFF1F5F9"
                                                        CornerRadius="4"
                                                        Padding="6,1"
                                                        Margin="0,0,12,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding CategorieLibelle}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource AsertiNavyBrush}"/>
                                                </Border>

                                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Message}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource AsertiNavyBrush}"/>
                                                    <TextBlock FontSize="10"
                                                               FontFamily="Cascadia Mono, Consolas"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0">
                                                        <Run Text="{Binding Action, Mode=OneWay}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding Details, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer statut -->
        <Border Grid.Row="4"
                Padding="24,12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Statut}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Button Grid.Column="1"
                        Content="Rafraîchir"
                        Command="{Binding RafraichirCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="16,8"
                        MinWidth="120"/>
                <Button Grid.Column="3"
                        Content="Fermer"
                        IsCancel="True"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="16,8"
                        MinWidth="120"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
