<ui:FluentWindow x:Class="Metrologo.Views.JournalViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Journal des interventions"
        Height="720" Width="1040"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Icon="/Resources/logo.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Journal des interventions">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/logo.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- En-tête -->
        <Border Grid.Row="1" Padding="24,14,24,8">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10"
                        Background="{StaticResource AsertiNavyBrush}" Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="History24" FontSize="22" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Journal des interventions"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="Une fiche (FI) par ligne — accès direct à son fichier journal."
                               FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Recherche -->
        <Border Grid.Row="2" Padding="24,0,24,8">
            <ui:TextBox Text="{Binding Recherche, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Rechercher une FI ou un opérateur…" Padding="10,6">
                <ui:TextBox.Icon>
                    <ui:SymbolIcon Symbol="Search24"/>
                </ui:TextBox.Icon>
            </ui:TextBox>
        </Border>

        <!-- Liste des fiches -->
        <Border Grid.Row="3" Margin="24,0,24,8" Background="White"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="10" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- En-têtes de colonnes -->
                <Grid Grid.Row="0" Margin="10,2,10,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="FICHE (FI)" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AsertiOrangeBrush}"/>
                    <TextBlock Grid.Column="1" Text="OPÉRATEUR(S)" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AsertiOrangeBrush}"/>
                    <TextBlock Grid.Column="2" Text="DERNIÈRE ACTIVITÉ" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AsertiOrangeBrush}"/>
                    <TextBlock Grid.Column="3" Text="MESURES" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AsertiOrangeBrush}"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Fiches}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,4"
                                        Background="White"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding NumFI}"
                                                   FontWeight="Bold" FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource AsertiNavyBrush}"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="1" Text="{Binding OperateursAffiches}"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource AsertiNavyBrush}"/>

                                        <TextBlock Grid.Column="2" Text="{Binding DerniereActiviteAffichee}"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                                        <Border Grid.Column="3" Background="#FFE0E7FF" CornerRadius="10"
                                                Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding NbMesures}" FontSize="11" FontWeight="Bold"
                                                       Foreground="#FF4338CA"/>
                                        </Border>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="📄 Journal"
                                                    Command="{Binding DataContext.OuvrirFichierCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Padding="12,6" Margin="0,0,6,0"
                                                    IsEnabled="{Binding LogPresent}"/>
                                            <Button Content="📁 Dossier"
                                                    Command="{Binding DataContext.OuvrirDossierCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="12,6"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Padding="24,12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Statut}"
                           VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Rafraîchir"
                            Command="{Binding RafraichirCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="14,8" MinWidth="100" Margin="0,0,8,0"/>
                    <Button Content="Fermer" IsCancel="True" IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="14,8" MinWidth="100"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
