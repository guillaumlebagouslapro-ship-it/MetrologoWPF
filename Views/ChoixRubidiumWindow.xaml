<ui:FluentWindow x:Class="Metrologo.Views.ChoixRubidiumWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Sélection du rubidium"
        Height="620" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Sélection du rubidium" ShowMaximize="False"/>

        <!-- En-tête -->
        <Border Grid.Row="1" Padding="24,12,24,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10"
                        Background="{StaticResource AsertiNavyBrush}"
                        Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="Timer24" FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Référence de fréquence"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="Choisissez le rubidium actif et le mode de raccordement"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,0,24,16">
            <StackPanel>

                <!-- Section Rubidium -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Timer24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Rubidium actif" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <!-- Sélecteur Mode : choisir un rubidium du catalogue OU saisir
                             une fréquence à la main (cas où aucun rubidium n'est raccordé
                             ou tests avec une fréquence de référence custom). -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="6" BorderThickness="1" Padding="14,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EstModeListe}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <RadioButton GroupName="ModeRub"
                                             IsChecked="{Binding EstModeListe, Mode=OneWay}"
                                             Checked="OnModeListeChecked"
                                             FontWeight="SemiBold">
                                    <StackPanel>
                                        <TextBlock Text="Catalogue" FontSize="13"/>
                                        <TextBlock Text="Choisir un rubidium prédéfini"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="22,2,0,0"/>
                                    </StackPanel>
                                </RadioButton>
                            </Border>

                            <Border Grid.Column="2" CornerRadius="6" BorderThickness="1" Padding="14,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ModeManuel}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <RadioButton GroupName="ModeRub"
                                             IsChecked="{Binding ModeManuel, Mode=TwoWay}"
                                             FontWeight="SemiBold">
                                    <StackPanel>
                                        <TextBlock Text="Réglage manuel" FontSize="13"/>
                                        <TextBlock Text="Saisir la fréquence à la main"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="22,2,0,0"/>
                                    </StackPanel>
                                </RadioButton>
                            </Border>
                        </Grid>

                        <!-- Mode Manuel : TextBox pour saisir la fréquence -->
                        <StackPanel Visibility="{Binding ModeManuel, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,8">
                            <TextBlock Text="FRÉQUENCE MOYENNE (Hz)" Style="{StaticResource FormLabelStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:TextBox Grid.Column="0"
                                            Text="{Binding FrequenceManuelleTexte, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="ex. 10000000"
                                            FontFamily="Cascadia Mono, Consolas"
                                            Padding="10,8"/>
                                <TextBlock Grid.Column="1" Text="Hz"
                                           VerticalAlignment="Center" Margin="10,0,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AsertiNavyBrush}"/>
                            </Grid>
                            <TextBlock Text="Cette valeur est utilisée comme fréquence de référence (ZNFreqRef) dans le calcul des incertitudes Excel."
                                       FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Bloc Liste (visible en mode Catalogue uniquement) -->
                        <StackPanel Visibility="{Binding EstModeListe, Converter={StaticResource BoolToVis}}">
                            <Border Visibility="{Binding ListeVide, Converter={StaticResource BoolToVis}}"
                                    Background="#FFFFF7ED"
                                    BorderBrush="#FFFED7AA"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="14,12"
                                    Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Info24" FontSize="18"
                                                   Foreground="{StaticResource AsertiOrangeBrush}"
                                                   Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="Aucun rubidium configuré"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="#FF7C2D12"/>
                                        <TextBlock Text="La liste sera chargée depuis la base de données des rubidiums."
                                                   FontSize="11"
                                                   Foreground="#FF9A3412"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <ListBox ItemsSource="{Binding Rubidiums}"
                                 SelectedItem="{Binding RubidiumSelectionne, Mode=TwoWay}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="b"
                                                        CornerRadius="6"
                                                        Padding="14,10"
                                                        Background="White"
                                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                        BorderThickness="1">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeLightBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                        <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                                                        <Setter TargetName="b" Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="32" Height="32" CornerRadius="8"
                                                Background="#FFDCFCE7"
                                                Margin="0,0,12,0">
                                            <ui:SymbolIcon Symbol="Timer24" FontSize="16"
                                                           Foreground="#FF16A34A"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Designation}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       Foreground="{StaticResource AsertiNavyBrush}"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                <Run Text="F moyenne : "/>
                                                <Run Text="{Binding FrequenceMoyenne, StringFormat={}{0:N2} Hz}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Id, StringFormat=ID #{0}}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Section Raccordement -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Pulse24" FontSize="18"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Mode de raccordement" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    Padding="14,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SansGPS}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="28" Height="28" CornerRadius="6"
                                            Background="#FFFEE2E2"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="📡"
                                                   FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <RadioButton Content="Allouis"
                                                     IsChecked="{Binding SansGPS, Mode=TwoWay}"
                                                     FontWeight="SemiBold"
                                                     GroupName="Raccord"/>
                                        <TextBlock Text="162 kHz ondes longues"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="24,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    Padding="14,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AvecGPS}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="28" Height="28" CornerRadius="6"
                                            Background="#FFDCFCE7"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="🛰"
                                                   FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <RadioButton Content="GPS"
                                                     IsChecked="{Binding AvecGPS, Mode=TwoWay}"
                                                     FontWeight="SemiBold"
                                                     GroupName="Raccord"/>
                                        <TextBlock Text="Raccordement satellitaire"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="24,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Message d'erreur -->
                <Border CornerRadius="6" Padding="12,10"
                        Background="#FFFEE2E2"
                        BorderBrush="#FFFCA5A5"
                        BorderThickness="1"
                        Margin="0,0,0,6"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Warning24" FontSize="16"
                                       Foreground="#FFDC2626"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding MessageErreur}"
                                   Foreground="#FF7F1D1D"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Barre de boutons -->
        <Border Grid.Row="3"
                Padding="24,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Annuler"
                        Command="{Binding AnnulerCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>

                <Button Grid.Column="2"
                        Content="Valider la sélection"
                        Command="{Binding ValiderCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
