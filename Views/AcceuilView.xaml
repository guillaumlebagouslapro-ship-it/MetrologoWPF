<UserControl x:Class="Metrologo.Views.AcceuilView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filigrane logo ASERTI : habille le fond blanc, très léger et non cliquable
             (IsHitTestVisible=False) pour ne pas gêner les boutons. ZIndex négatif = tout
             en arrière-plan, derrière le contenu. -->
        <Image Source="/Resources/logo-filigrane.png"
               Grid.Row="0" Grid.RowSpan="5"
               Opacity="0.07"
               Width="680"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               IsHitTestVisible="False"
               Panel.ZIndex="-1"/>

        <!-- Bandeau d'en-tête -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Tableau de bord"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource AsertiNavyBrush}"/>
                <TextBlock Text="Lancez une mesure ou consultez les paramètres de votre banc"
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Changer d'utilisateur : accessible directement depuis l'accueil si on s'aperçoit
                 ici qu'on n'est pas le bon opérateur. Lié à la commande du MainViewModel (fenêtre
                 parente), car le DataContext de cette vue est l'AccueilViewModel. -->
            <ui:Button Grid.Column="1"
                       VerticalAlignment="Center"
                       Appearance="Secondary"
                       Cursor="Hand"
                       Command="{Binding DataContext.ChangerUtilisateurCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                       ToolTip="Revenir à l'écran de connexion pour changer d'opérateur">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Person24" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="Changer d'utilisateur" VerticalAlignment="Center"/>
                </StackPanel>
            </ui:Button>
        </Grid>

        <!-- Bandeau "Fiche en cours" — visible dès qu'une configuration a été validée.
             Affiche en gros le N° FI sur lequel on travaille + type de mesure + appareil. -->
        <Border Grid.Row="1"
                Visibility="{Binding EstConfigure, Converter={StaticResource BoolToVis}}"
                Background="{StaticResource AsertiNavyBrush}"
                CornerRadius="10"
                Padding="22,16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12"
                        Margin="0,0,18,0" VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush Color="White" Opacity="0.18"/>
                    </Border.Background>
                    <ui:SymbolIcon Symbol="DocumentText24" FontSize="28"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="FICHE EN COURS"
                               FontSize="11" FontWeight="Bold"
                               Foreground="White" Opacity="0.7"/>
                    <TextBlock Text="{Binding MesureConfig.NumFI}"
                               FontSize="34" FontWeight="Bold"
                               Foreground="White"
                               FontFamily="Cascadia Mono, Consolas"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="TYPE DE MESURE"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="White" Opacity="0.7"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding MesureConfig.TypeMesure}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding LibelleAppareilConfigure}"
                                   FontSize="12"
                                   Foreground="White" Opacity="0.8"
                                   HorizontalAlignment="Right"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Bouton crayon : ouvre la configuration sans relancer une mesure
                         (pour modifier un paramètre entre deux exécutions). Remplace
                         l'ancien bouton « Configuration » de la grille de cartes. -->
                    <Button Command="{Binding OuvrirConfigurationCommand}"
                            ToolTip="Modifier la configuration"
                            Cursor="Hand"
                            Margin="16,0,0,0"
                            Padding="10"
                            BorderThickness="0"
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="White" Opacity="0.18"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="White" Opacity="0.32"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <ui:SymbolIcon Symbol="Edit24" FontSize="20" Foreground="White"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Cartes d'actions -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Exécuter (action primaire orange) -->
            <Button Grid.Column="0"
                    Command="{Binding ExecuterMesureCommand}"
                    Cursor="Hand"
                    BorderThickness="0"
                    Padding="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="10" Padding="20"
                                Background="{StaticResource AsertiOrangeBrush}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.2" Color="{StaticResource AsertiOrangeDarkColor}"/>
                            </Border.Effect>
                            <StackPanel>
                                <Border Width="44" Height="44" CornerRadius="10"
                                        HorizontalAlignment="Left" Margin="0,0,0,14">
                                    <Border.Background>
                                        <SolidColorBrush Color="White" Opacity="0.22"/>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="Play24" FontSize="24"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="EXÉCUTER" FontSize="11" FontWeight="Bold"
                                           Foreground="White" Opacity="0.85" Margin="0,0,0,2"/>
                                <TextBlock Text="Lancer la mesure" FontSize="16" FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock Text="Démarre l'acquisition sur l'instrument configuré"
                                           FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="White" Opacity="0.85"/>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AsertiOrangeDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Relancer (mêmes paramètres) -->
            <Button Grid.Column="2"
                    Command="{Binding RelancerMesureCommand}"
                    Style="{StaticResource ActionCardStyle}">
                <StackPanel>
                    <Border Width="44" Height="44" CornerRadius="10"
                            HorizontalAlignment="Left" Margin="0,0,0,14"
                            Background="#FFFFF0D9">
                        <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="22"
                                       Foreground="{StaticResource AsertiOrangeDarkBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="RELANCER" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,2"/>
                    <TextBlock Text="Même mesure"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="Rejoue avec les mêmes paramètres que la dernière exécution"
                               FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Button>

            <!-- Stop : style amplifié quand une mesure tourne (fond rouge vif, bordure
                 épaisse, texte plus gros). Bascule en "Arrêt en cours…" dès le clic
                 pour donner un feedback visuel instantané, le temps que le Device Clear
                 + token soient honorés par le compteur (qq centaines de ms max). -->
            <Button Grid.Column="4"
                    Command="{Binding StopperMesureCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ActionCardStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding MesureEnCours}" Value="True">
                                <Setter Property="BorderBrush" Value="#FFDC2626"/>
                                <Setter Property="BorderThickness" Value="3"/>
                                <Setter Property="Background" Value="#FFFFE4E4"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel>
                    <Border Width="44" Height="44" CornerRadius="10"
                            HorizontalAlignment="Left" Margin="0,0,0,14">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#FFFEE2E2"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MesureEnCours}" Value="True">
                                        <Setter Property="Background" Value="#FFDC2626"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <ui:SymbolIcon Symbol="Stop24" FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Foreground" Value="#FFDC2626"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MesureEnCours}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </Border>
                    <TextBlock Text="STOP" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,2"/>
                    <TextBlock FontSize="16" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Arrêter"/>
                                <Setter Property="Foreground" Value="{StaticResource AsertiNavyBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ArretEnCours}" Value="True">
                                        <Setter Property="Text" Value="Arrêt en cours…"/>
                                        <Setter Property="Foreground" Value="#FFDC2626"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding MesureEnCours}" Value="True"/>
                                            <Condition Binding="{Binding ArretEnCours}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Text" Value="Arrêter la mesure"/>
                                        <Setter Property="Foreground" Value="#FFDC2626"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Interrompt la mesure en cours"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MesureEnCours}" Value="True">
                                        <Setter Property="Text" Value="Cliquez pour stopper immédiatement"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Button>

        </Grid>

        <!-- Panneau Suivi Besançon — voyant d'état + rapport texte indenté -->
        <Border Grid.Row="3"
                Visibility="{Binding BesanconVisible, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- En-tête : voyant + titre/détail + bouton Actualiser -->
                <Border Grid.Row="0"
                        Padding="18,12"
                        CornerRadius="10,10,0,0"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        Background="{DynamicResource LayerFillColorDefaultBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Ellipse Grid.Column="0" Width="16" Height="16"
                                 Fill="{Binding BesanconVoyant}"
                                 VerticalAlignment="Center" Margin="0,0,12,0">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.25"/>
                            </Ellipse.Effect>
                        </Ellipse>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding BesanconTitre}"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource AsertiNavyBrush}"/>
                            <TextBlock Text="{Binding BesanconDetail}"
                                       FontSize="12" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Command="{Binding RafraichirBesanconCommand}"
                                ToolTip="Réévaluer le suivi Besançon"
                                Cursor="Hand"
                                Padding="10,6"
                                VerticalAlignment="Center"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                Background="White">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="14"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Actualiser"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource AsertiNavyBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <TextBox Grid.Row="1"
                         Text="{Binding BesanconRapport}"
                         IsReadOnly="True"
                         MaxHeight="200"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="12"
                         Padding="18,12"
                         BorderThickness="0"
                         Background="Transparent"/>
            </Grid>
        </Border>

        <!-- Panneau Informations Générales -->
        <Border Grid.Row="4"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="18,14"
                        CornerRadius="10,10,0,0"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        Background="{DynamicResource LayerFillColorDefaultBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="6"
                                    Background="{StaticResource AsertiNavyBrush}"
                                    Margin="0,0,10,0">
                                <ui:SymbolIcon Symbol="DocumentBulletList24" FontSize="16"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Informations générales"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource AsertiNavyBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Background="#FFDCFCE7" CornerRadius="10"
                                    Padding="8,2" Margin="14,0,0,0"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="#FF16A34A"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Prêt" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#FF166534"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Bouton : ouvre le dossier Documents\Metrologo dans l'Explorateur -->
                        <Button Grid.Column="1"
                                Command="{Binding OuvrirDossierMesuresCommand}"
                                ToolTip="Ouvrir le dossier contenant les fichiers Excel de mesure"
                                Cursor="Hand"
                                Padding="10,6"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                Background="White">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14"
                                               Foreground="{StaticResource AsertiNavyBrush}"
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Dossier des mesures"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource AsertiNavyBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <TextBox Grid.Row="1"
                         Text="{Binding InformationsGenerales}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="12"
                         Padding="18,14"
                         BorderThickness="0"
                         Background="Transparent"
                         TextChanged="LogTextBox_TextChanged"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
