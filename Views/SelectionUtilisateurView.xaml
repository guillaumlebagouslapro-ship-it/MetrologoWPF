<UserControl x:Class="Metrologo.Views.SelectionUtilisateurView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid>
        <Border MaxWidth="1000" MaxHeight="600"
                CornerRadius="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="3" Opacity="0.12"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ====== PANNEAU GAUCHE : BRAND + INFO ====== -->
                <Border Grid.Column="0" CornerRadius="16,0,0,16" ClipToBounds="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                            <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <!-- Décorations background -->
                        <Ellipse Width="320" Height="320"
                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Margin="0,-120,-140,0" Opacity="0.15">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{StaticResource AsertiOrangeColor}"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="220" Height="220"
                                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                 Margin="-100,0,0,-80" Opacity="0.10">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="White"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <Grid Margin="32,28,32,28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header : logo + version -->
                            <StackPanel Grid.Row="0">
                                <!-- Logo couleur sur cartouche blanc (comme la barre de navigation) :
                                     il ressort nettement sur le fond navy, SANS artefact de détourage
                                     (le détourage d'un logo raster laisse des bords colorés sur fond sombre). -->
                                <Border Background="White"
                                        CornerRadius="8"
                                        Padding="14,10"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,18">
                                    <Image Source="/Resources/aserti-logo.png"
                                           Height="40"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <Border CornerRadius="20" Padding="10,4"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource AsertiOrangeBrush}">
                                    <TextBlock Text="{Binding VersionApp}"
                                               Foreground="White"
                                               FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>

                            <!-- Centre : titre + tagline -->
                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                <TextBlock Text="METROLOGO"
                                           FontSize="42" FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,8"/>
                                <Rectangle Height="3" Width="50"
                                           HorizontalAlignment="Left"
                                           Margin="0,0,0,14">
                                    <Rectangle.Fill>
                                        <SolidColorBrush Color="{StaticResource AsertiOrangeColor}"/>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <TextBlock Text="Calibration &amp; métrologie"
                                           FontSize="15" FontWeight="SemiBold">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="White" Opacity="0.92"/>
                                    </TextBlock.Foreground>
                                </TextBlock>
                                <TextBlock Text="Fréquence · Stabilité · Intervalle · Tachymétrie · Stroboscope"
                                           FontSize="11" TextWrapping="Wrap"
                                           Margin="0,8,0,0">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="White" Opacity="0.62"/>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>

                            <!-- Footer : date/heure (mise à jour en continu par le ViewModel) -->
                            <StackPanel Grid.Row="2">
                                <Rectangle Height="1" Margin="0,0,0,16">
                                    <Rectangle.Fill>
                                        <SolidColorBrush Color="White" Opacity="0.18"/>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <StackPanel Orientation="Horizontal">
                                    <Border Width="28" Height="28" CornerRadius="8"
                                            Margin="0,0,10,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.14"/>
                                        </Border.Background>
                                        <ui:SymbolIcon Symbol="Calendar24" FontSize="14"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="DATE" FontSize="9" FontWeight="Bold">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{StaticResource AsertiOrangeLightColor}"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                                   Foreground="White">
                                            <Run Text="{Binding DateActuelle, Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding HeureActuelle, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ====== PANNEAU DROIT : LOGIN ====== -->
                <Border Grid.Column="1" Background="White" CornerRadius="0,16,16,0">
                    <Grid Margin="48,32,48,32">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- En-tête -->
                        <StackPanel Grid.Row="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Width="32" Height="32" CornerRadius="8"
                                        Background="#FFFEF3C7"
                                        Margin="0,0,10,0">
                                    <ui:SymbolIcon Symbol="People24" FontSize="16"
                                                   Foreground="#FFD97706"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="CONNEXION"
                                           FontSize="11" FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AsertiOrangeBrush}"/>
                            </StackPanel>
                            <TextBlock Text="Qui se connecte ?"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource AsertiNavyBrush}"
                                       Margin="0,4,0,8"/>
                            <TextBlock Text="Sélectionne ton nom dans la liste pour démarrer la session."
                                       FontSize="12" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,24"/>
                        </StackPanel>

                        <!-- Zone dropdown + warning -->
                        <StackPanel Grid.Row="1" VerticalAlignment="Top">
                            <!-- Liste vide : avertissement -->
                            <Border Visibility="{Binding ListeVide, Converter={StaticResource BoolToVis}}"
                                    Background="#FFFFF7ED"
                                    BorderBrush="#FFFED7AA"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16,14"
                                    Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Warning24" FontSize="22"
                                                   Foreground="{StaticResource AsertiOrangeBrush}"
                                                   Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="Aucun utilisateur enregistré"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="#FF7C2D12"/>
                                        <TextBlock Text="Ouvre Administration puis « Utilisateurs » pour créer le premier compte. Le mot de passe administrateur par défaut est « admin »."
                                                   FontSize="11"
                                                   Foreground="#FF9A3412"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="UTILISATEUR"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource AsertiOrangeBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding NombreComptesTexte}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <ComboBox ItemsSource="{Binding Utilisateurs}"
                                      SelectedItem="{Binding UtilisateurSelectionne, Mode=TwoWay}"
                                      FontSize="14"
                                      Padding="12,10"
                                      Margin="0,0,0,16">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                                    Margin="0,0,12,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <!-- Utilisateur : gris -->
                                                        <Setter Property="Background" Value="#FF94A3B8"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Role}" Value="Administrateur">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                            <GradientStop Color="{StaticResource AsertiOrangeDarkColor}" Offset="0"/>
                                                                            <GradientStop Color="{StaticResource AsertiOrangeColor}" Offset="1"/>
                                                                        </LinearGradientBrush>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Role}" Value="SuperAdministrateur">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                            <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                                                                            <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                                                                        </LinearGradientBrush>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Foreground="White" FontWeight="Bold" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0:1}{1:1}">
                                                            <Binding Path="Prenom"/>
                                                            <Binding Path="Nom"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{StaticResource AsertiNavyBrush}">
                                                    <Run Text="{Binding Prenom, Mode=OneWay}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Nom, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Login}"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>

                                            <!-- Badge rôle (visible uniquement si Admin ou SuperAdmin) -->
                                            <Border Grid.Column="2" CornerRadius="10" Padding="8,3"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Setter Property="Background" Value="{StaticResource AsertiOrangeBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Role}" Value="Administrateur">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Setter Property="Background" Value="{StaticResource AsertiOrangeBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Role}" Value="SuperAdministrateur">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Setter Property="Background" Value="{StaticResource AsertiNavyBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon FontSize="10"
                                                                   Foreground="White"
                                                                   Margin="0,0,4,0" VerticalAlignment="Center">
                                                        <ui:SymbolIcon.Style>
                                                            <Style TargetType="ui:SymbolIcon">
                                                                <Setter Property="Symbol" Value="ShieldKeyhole24"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Role}" Value="SuperAdministrateur">
                                                                        <Setter Property="Symbol" Value="Star24"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:SymbolIcon.Style>
                                                    </ui:SymbolIcon>
                                                    <TextBlock FontSize="9" FontWeight="Bold"
                                                               Foreground="White" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="ADMIN"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Role}" Value="SuperAdministrateur">
                                                                        <Setter Property="Text" Value="SUPER ADMIN"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            
                            
                        </StackPanel>

                        <!-- Bouton Continuer -->
                        <Button Grid.Row="2"
                                Command="{Binding ContinuerCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="0,14"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Continuer vers le choix du poste"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="White"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <ui:SymbolIcon Symbol="ArrowRight24" FontSize="16"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
