<ui:FluentWindow x:Class="Metrologo.Views.ReseauIndisponibleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Réseau indisponible"
        Height="380" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Icon="/Resources/logo.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Réseau indisponible" ShowMaximize="False" ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/logo.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Bandeau -->
        <Border Grid.Row="1" CornerRadius="10" Padding="20,16" Margin="20,16,20,12"
                Effect="{StaticResource BannerShadow}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FFB91C1C" Offset="0"/>
                    <GradientStop Color="#FFDC2626" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12"
                        Margin="0,0,16,0">
                    <Border.Background>
                        <SolidColorBrush Color="White" Opacity="0.22"/>
                    </Border.Background>
                    <ui:SymbolIcon Symbol="PlugDisconnected24" FontSize="26"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="CONNEXION RÉSEAU REQUISE" FontSize="11" FontWeight="Bold"
                               Foreground="White" Opacity="0.85"/>
                    <TextBlock Text="Le logiciel n'est pas relié au réseau"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Les fichiers partagés du serveur sont inaccessibles depuis ce poste."
                               FontSize="12"
                               Foreground="White" Opacity="0.85"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Détail + statut -->
        <StackPanel Grid.Row="2" Margin="20,0,20,12">
            <TextBlock TextWrapping="Wrap" FontSize="13"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                <Run Text="Le partage serveur"/>
                <Run x:Name="RunChemin" Text="" FontWeight="Bold"/>
                <Run Text="n'est pas joignable. Vérifie le câble réseau, le VPN ou le montage du lecteur, puis clique sur « Rafraîchir » pour relancer l'accès aux fichiers réseau."/>
            </TextBlock>

            <Border x:Name="BordureStatut" CornerRadius="8" Padding="12,10" Margin="0,12,0,0"
                    Background="#FFFEE2E2" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon x:Name="IconeStatut" Symbol="ErrorCircle24" FontSize="16"
                                   Foreground="#FFDC2626" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TbStatut" Margin="8,0,0,0" FontSize="12"
                               Foreground="#FF991B1B" VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Text="Le partage est toujours inaccessible."/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Boutons -->
        <Border Grid.Row="3" Padding="20,12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnFermer" Grid.Column="0"
                        Content="Fermer l'application"
                        Click="OnFermer"
                        Style="{StaticResource SecondaryButtonStyle}"/>

                <Button x:Name="BtnRafraichir" Grid.Column="2"
                        Content="Rafraîchir"
                        Click="OnRafraichir"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
