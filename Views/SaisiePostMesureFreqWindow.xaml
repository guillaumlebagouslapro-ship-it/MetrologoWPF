<ui:FluentWindow x:Class="Metrologo.Views.SaisiePostMesureFreqWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Saisie post-mesure"
        Height="640" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Topmost="True"
        ShowInTaskbar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Saisie post-mesure" ShowMaximize="False"/>

        <Border Grid.Row="1" Padding="24,12,24,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10"
                        Background="{StaticResource AsertiNavyBrush}"
                        Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="Keyboard24" FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Saisie post-mesure"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="Fréquence lue sur l'afficheur, résolution et incertitude sup. relative"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,0,24,16">
            <StackPanel>
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="FRÉQUENCE LUE (HZ)"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <ui:TextBox x:Name="txtFreq"
                                    Text="{Binding FrequenceLueTexte, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="10000000"
                                    FontFamily="Cascadia Mono, Consolas"
                                    FontSize="18"
                                    Padding="12,10"
                                    Margin="0,0,0,4">
                            <ui:TextBox.Icon>
                                <ui:SymbolIcon Symbol="NumberSymbol24"/>
                            </ui:TextBox.Icon>
                        </ui:TextBox>
                        <TextBlock Text="Valeur affichée par le fréquencemètre."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="RÉSOLUTION (HZ)"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <ui:TextBox Text="{Binding ResolutionTexte, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="0.01"
                                    FontFamily="Cascadia Mono, Consolas"
                                    Padding="10,8"
                                    Margin="0,0,0,4">
                            <ui:TextBox.Icon>
                                <ui:SymbolIcon Symbol="Ruler24"/>
                            </ui:TextBox.Icon>
                        </ui:TextBox>
                        <TextBlock Text="Résolution du compteur (dernier digit affiché)."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="INCERTITUDE SUP. RELATIVE (DÉGRADATION)"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <ui:TextBox Text="{Binding IncertSuppTexte, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="0.0"
                                    FontFamily="Cascadia Mono, Consolas"
                                    Padding="10,8"
                                    Margin="0,0,0,4">
                            <ui:TextBox.Icon>
                                <ui:SymbolIcon Symbol="MathFormula24"/>
                            </ui:TextBox.Icon>
                        </ui:TextBox>
                        <TextBlock Text="Dégradation relative ajoutée au bilan (sans unité)."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="6" Padding="12,10"
                        Background="#FFFEE2E2"
                        BorderBrush="#FFFCA5A5"
                        BorderThickness="1"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Warning24" FontSize="16"
                                       Foreground="#FFDC2626"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding MessageErreur}"
                                   Foreground="#FF7F1D1D"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3"
                Padding="24,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Annuler"
                        Command="{Binding AnnulerCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>

                <Button Grid.Column="2"
                        Content="Valider"
                        Command="{Binding ValiderCommand}"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
