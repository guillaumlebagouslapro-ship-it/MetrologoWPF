<ui:FluentWindow x:Class="Metrologo.Views.AjoutModuleIncertitudeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Nouveau module d'incertitude"
        Height="350" Width="480"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Nouveau module"/>

        <StackPanel Grid.Row="1" Margin="24,16,24,0">
            <TextBlock Text="Le numéro de module sert de nom de fichier (.csv). Une fois créé, ajoute les lignes du tableau d'incertitudes dans la fenêtre principale."
                       TextWrapping="Wrap" FontSize="12" Margin="0,0,0,16" Opacity="0.85"/>

            <TextBlock Text="N° Module (= nom du fichier CSV)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ui:TextBox x:Name="TbNumModule" PlaceholderText="ex. MF51901A" Margin="0,0,0,12"/>

            <TextBlock Text="Nom d'affichage (optionnel)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ui:TextBox x:Name="TbNomAffichage" PlaceholderText="ex. Compteur de fréquence MF51901A"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,24,16">
            <ui:Button Appearance="Secondary" Content="Annuler" Click="OnAnnuler" Margin="0,0,8,0"/>
            <ui:Button Appearance="Primary" Content="Créer" Click="OnValider"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
