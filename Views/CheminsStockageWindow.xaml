<ui:FluentWindow x:Class="Metrologo.Views.CheminsStockageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Chemins de stockage"
        Height="720" Width="900"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Icon="/Resources/logo.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Chemins de stockage">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/logo.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Border Grid.Row="1" CornerRadius="10" Padding="20,16" Margin="20,16,20,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock Text="ZONE ADMINISTRATEUR" FontSize="11" FontWeight="Bold" Margin="0,0,0,4">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="{StaticResource AsertiOrangeLightColor}"/>
                    </TextBlock.Foreground>
                </TextBlock>
                <TextBlock Text="Chemins de stockage des données" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="White" Opacity="0.78"/>
                    </TextBlock.Foreground>
                    <Run Text="Surcharge les emplacements par défaut pour pointer vers un partage réseau commun à tous les postes du site (modules d'incertitude, presets, etc.). Laisse un champ vide pour utiliser le défaut local. La BDD SQL Server (catalogue, journal, sessions) reste centralisée et n'est PAS configurable ici."/>
                </TextBlock>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" Padding="20,0,20,12" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Incertitudes -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Modules d'incertitude" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Coefficients d'incertitude par appareil et par type de mesure (CSV par catégorie). Sur réseau = même tableau d'incertitudes accréditées sur tous les postes."/>
                            <LineBreak/>
                            <Run Text="Défaut local : "/>
                            <Run FontFamily="Cascadia Mono, Consolas" Text="%LocalAppData%\Metrologo\Incertitudes"/>
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding CheminIncertitudes, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="\\serveur\Metrologo\Incertitudes  (vide = défaut local)"
                                        FontFamily="Cascadia Mono, Consolas" Padding="10,6"/>
                            <Button Grid.Column="1" Content="Parcourir..."
                                    Command="{Binding ParcourirIncertitudesCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="8,0,0,0" Padding="14,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Presets -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Presets de stabilité" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Combinaisons de gates prédéfinies pour les mesures de stabilité (ex. balayage 4 gates, balayage Allan complet). Partage réseau = mêmes presets sur tous les postes."/>
                            <LineBreak/>
                            <Run Text="Défaut local : "/>
                            <Run FontFamily="Cascadia Mono, Consolas" Text="%LocalAppData%\Metrologo\Presets"/>
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding CheminPresets, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="\\serveur\Metrologo\Presets  (vide = défaut local)"
                                        FontFamily="Cascadia Mono, Consolas" Padding="10,6"/>
                            <Button Grid.Column="1" Content="Parcourir..."
                                    Command="{Binding ParcourirPresetsCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="8,0,0,0" Padding="14,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Catalogues -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Backups d'imports catalogue" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Backups JSON des modèles d'appareils importés (post-migration). La BDD SQL Server reste la source vivante du catalogue ; ce dossier est utile pour archiver les fichiers d'import."/>
                            <LineBreak/>
                            <Run Text="Défaut local : "/>
                            <Run FontFamily="Cascadia Mono, Consolas" Text="%LocalAppData%\Metrologo\Catalogues"/>
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding CheminCatalogues, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="\\serveur\Metrologo\Catalogues  (vide = défaut local)"
                                        FontFamily="Cascadia Mono, Consolas" Padding="10,6"/>
                            <Button Grid.Column="1" Content="Parcourir..."
                                    Command="{Binding ParcourirCataloguesCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="8,0,0,0" Padding="14,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Archives Logs -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Archives des logs" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Logs archivés mois par mois (export du journal SQL Server). Sur partage réseau = consultation centralisée + sauvegarde des logs anciens hors BDD."/>
                            <LineBreak/>
                            <Run Text="Défaut local : "/>
                            <Run FontFamily="Cascadia Mono, Consolas" Text="%LocalAppData%\Metrologo\ArchivesLogs"/>
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding CheminArchivesLogs, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="\\serveur\Metrologo\Archives  (vide = défaut local)"
                                        FontFamily="Cascadia Mono, Consolas" Padding="10,6"/>
                            <Button Grid.Column="1" Content="Parcourir..."
                                    Command="{Binding ParcourirArchivesLogsCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="8,0,0,0" Padding="14,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Synchronisation multi-postes (fichier maître serveur) -->
                <Border Style="{StaticResource FormSectionStyle}"
                        Background="#FFEFF6FF" BorderBrush="#FFBFDBFE" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Synchronisation multi-postes (avancé)" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Pour qu'un changement de chemins faits ici se propage AUTOMATIQUEMENT à tous les autres postes Metrologo, renseigne le chemin du fichier maître sur le serveur. Tous les postes liront ce fichier au démarrage et s'aligneront dessus."/>
                            <LineBreak/>
                            <Run FontWeight="Bold" Text="Cas type :"/><Run Text=" si tu déplaces un jour ton dossier "/>
                            <Run FontFamily="Cascadia Mono, Consolas" Text="\\serveur1\..."/>
                            <Run Text=" vers "/>
                            <Run FontFamily="Cascadia Mono, Consolas" Text="\\serveur2\..."/>
                            <Run Text=", tu modifies ici une seule fois (coche « Appliquer à tous »), tous les postes suivent."/>
                        </TextBlock>
                        <TextBlock Text="FICHIER MAÎTRE (sur le serveur)" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AsertiNavyBrush}" Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding MasterPathsUrl, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="M:\exe_spe\Data_Metrologo\paths.config.json"
                                    FontFamily="Cascadia Mono, Consolas" Padding="10,6"
                                    Margin="0,0,0,10"/>
                        <CheckBox IsChecked="{Binding AppliquerATousLesPostes, Mode=TwoWay}"
                                  Content="Appliquer à tous les postes (écrit le fichier maître ci-dessus en plus du cache local)"
                                  FontWeight="SemiBold"/>
                        <TextBlock FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="• Décoché ➜ modification valable uniquement sur CE poste."/>
                            <LineBreak/>
                            <Run Text="• Coché ➜ modification propagée à tous les postes au prochain démarrage de Metrologo (l'admin doit avoir les droits d'écriture sur le fichier maître)."/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Mesures - chemin réseau (partagé entre postes) -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Mesures — chemin réseau (partagé)" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Chemin RÉSEAU où chaque rapport Excel est dupliqué automatiquement après la mesure. Permet à tous les postes du laboratoire de retrouver les rapports au même endroit."/>
                            <LineBreak/>
                            <Run Text="Par défaut : "/>
                            <Run FontFamily="Cascadia Mono, Consolas" Text="M:\exe_spe\Data_Metrologo\Mesures"/>
                            <Run Text=". Le fichier principal est toujours conservé localement sur le poste (Documents\Metrologo) en plus de cette copie réseau. Vide = pas de duplication réseau."/>
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding CheminMesuresLocal, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="M:\exe_spe\Data_Metrologo\Mesures  (vide = pas de duplication réseau)"
                                        FontFamily="Cascadia Mono, Consolas" Padding="10,6"/>
                            <Button Grid.Column="1" Content="Parcourir..."
                                    Command="{Binding ParcourirMesuresLocalCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="8,0,0,0" Padding="14,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Toujours locaux (info) -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Toujours locaux (non configurables)" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Ces emplacements contiennent des données par poste / des secrets et ne doivent jamais être partagés sur réseau."/>
                        </TextBlock>
                        <TextBlock Margin="0,0,0,4" FontSize="11">
                            <Run FontWeight="SemiBold" Text="Configuration : "/>
                            <Run FontFamily="Cascadia Mono, Consolas" Text="{Binding CheminConfiguration, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock FontSize="10" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="settings.json (préférences UI), db.credentials (DPAPI lié au profil Windows)"/>
                        <TextBlock Margin="0,0,0,4" FontSize="11">
                            <Run FontWeight="SemiBold" Text="Cache : "/>
                            <Run FontFamily="Cascadia Mono, Consolas" Text="{Binding CheminCache, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock FontSize="10"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="journal.db (cache local SQLite legacy), caches divers"/>
                    </StackPanel>
                </Border>

                <!-- Localisation du fichier de config -->
                <TextBlock TextWrapping="Wrap" FontSize="10" Margin="0,8,0,0"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                    <Run Text="Configuration enregistrée dans : "/>
                    <Run FontFamily="Cascadia Mono, Consolas" Text="{Binding CheminFichierConfig, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <!-- Pied : actions -->
        <Border Grid.Row="3" Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding Statut}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button Appearance="Secondary" Content="Tester"
                               Command="{Binding TesterCommand}" Margin="0,0,8,0"/>
                    <ui:Button Appearance="Secondary" Content="Réinitialiser"
                               Command="{Binding ReinitialiserCommand}" Margin="0,0,8,0"/>
                    <ui:Button Appearance="Secondary" Content="Annuler"
                               Command="{Binding AnnulerCommand}" Margin="0,0,8,0"/>
                    <ui:Button Appearance="Primary" Content="Enregistrer"
                               Command="{Binding EnregistrerCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
