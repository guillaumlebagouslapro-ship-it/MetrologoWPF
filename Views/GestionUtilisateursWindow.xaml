<ui:FluentWindow x:Class="Metrologo.Views.GestionUtilisateursWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Gestion des utilisateurs"
        Height="680" Width="980"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <!-- Carte utilisateur (DataTemplate appliqué à chaque ligne de la ListView).
             Le styling hover/sélection est géré ici via RelativeSource sur ListViewItem
             — l'ItemContainerStyle reste 100 % transparent pour éviter la double
             couche (highlight système + background custom) qui causait l'artefact bleu. -->
        <DataTemplate x:Key="UtilisateurCardTemplate">
            <Border CornerRadius="10" Padding="14" Margin="0,0,0,8"
                    BorderThickness="1"
                    SnapsToDevicePixels="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsMouseOver}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar circulaire (initiales) -->
                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24"
                            VerticalAlignment="Center" Margin="0,0,14,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                                <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Foreground="White" FontWeight="Bold" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:1}{1:1}">
                                    <Binding Path="Prenom"/>
                                    <Binding Path="Nom"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>

                    <!-- Identité -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource AsertiNavyBrush}">
                            <Run Text="{Binding Prenom}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding Nom}"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <ui:SymbolIcon Symbol="Person24" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Login}" FontFamily="Consolas" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <ui:SymbolIcon Symbol="Calendar24" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="Créé le"/>
                                <Run Text="{Binding DateCreation, StringFormat=dd/MM/yyyy, Mode=OneWay}"/>
                                <Run Text=" · Dernier login : "/>
                                <Run Text="{Binding DernierLogin, StringFormat=dd/MM/yyyy HH:mm, TargetNullValue=jamais, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Badge rôle -->
                    <Border Grid.Column="2" CornerRadius="12" Padding="10,4" Margin="8,0"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Role}" Value="Administrateur">
                                        <Setter Property="Background" Value="{StaticResource AsertiOrangeBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Symbol" Value="Person24"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Role}" Value="Administrateur">
                                                <Setter Property="Symbol" Value="ShieldKeyhole24"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                            <TextBlock Text="{Binding Role}" FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Role}" Value="Administrateur">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Indicateur Actif -->
                    <Border Grid.Column="3" Width="10" Height="10" CornerRadius="5"
                            VerticalAlignment="Center" Margin="8,0,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#FF16A34A"/>
                                <Setter Property="ToolTip" Value="Compte actif"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Actif}" Value="False">
                                        <Setter Property="Background" Value="#FFB91C1C"/>
                                        <Setter Property="ToolTip" Value="Compte désactivé"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Style ListViewItem 100 % neutre : le rendu visuel (hover, sélection)
             est entièrement géré dans le DataTemplate. On retire ici le ControlTemplate
             par défaut WPF qui sinon dessine son propre highlight bleu système au-dessus. -->
        <Style x:Key="UtilisateurItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Gestion des utilisateurs"/>

        <!-- Bandeau intro -->
        <Border Grid.Row="1" CornerRadius="10" Padding="20,16" Margin="20,16,20,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="ZONE ADMINISTRATEUR" FontSize="11" FontWeight="Bold" Margin="0,0,0,4">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{StaticResource AsertiOrangeLightColor}"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Gérer les comptes utilisateurs"
                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Créer un compte (login + mot de passe générés), réinitialiser un mot de passe oublié, ou supprimer un compte."
                               FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="White" Opacity="0.78"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>

                <!-- Compteur d'utilisateurs -->
                <Border Grid.Column="1" CornerRadius="8" Padding="14,8" VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush Color="White" Opacity="0.18"/>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="People24" Foreground="White" FontSize="20"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Foreground="White" FontWeight="Bold" FontSize="20"
                                   VerticalAlignment="Center"
                                   Text="{Binding Utilisateurs.Count}"/>
                        <TextBlock Foreground="White" Opacity="0.78" FontSize="12"
                                   VerticalAlignment="Bottom" Margin="6,0,0,3"
                                   Text="utilisateur(s)"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Boutons d'action -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="20,0,20,12">
            <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon PersonAdd24}"
                       Content="Ajouter un utilisateur"
                       Command="{Binding AjouterCommand}" Margin="0,0,8,0"/>
            <ui:Button Appearance="Caution" Icon="{ui:SymbolIcon Key24}"
                       Content="Réinit. mot de passe"
                       Command="{Binding ReinitialiserMotDePasseCommand}" Margin="0,0,8,0"/>
            <ui:Button Appearance="Danger" Icon="{ui:SymbolIcon PersonDelete24}"
                       Content="Supprimer"
                       Command="{Binding SupprimerCommand}" Margin="0,0,8,0"/>
            <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon ArrowSync24}"
                       Content="Rafraîchir"
                       Command="{Binding RafraichirCommand}"/>
        </StackPanel>

        <!-- Liste cartes utilisateurs -->
        <ScrollViewer Grid.Row="3" Margin="20,0,20,12" VerticalScrollBarVisibility="Auto">
            <Grid>
                <ListView ItemsSource="{Binding Utilisateurs}"
                          SelectedItem="{Binding Selection, Mode=TwoWay}"
                          ItemTemplate="{StaticResource UtilisateurCardTemplate}"
                          ItemContainerStyle="{StaticResource UtilisateurItemStyle}"
                          BorderThickness="0" Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>

                <!-- État vide -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="0,40,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Utilisateurs.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ui:SymbolIcon Symbol="People24" FontSize="48" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Text="Aucun utilisateur" FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="Cliquez sur « Ajouter un utilisateur » pour créer le premier compte."
                               FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Barre de statut -->
        <Border Grid.Row="4" Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="20,8">
            <TextBlock Text="{Binding Statut}" FontSize="12"/>
        </Border>
    </Grid>
</ui:FluentWindow>
