<ui:FluentWindow x:Class="Metrologo.Views.DispIncertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Incertitudes de mesure"
        Height="760" Width="1180"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FFFAFAFA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style x:Key="GridSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AsertiNavyBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Incertitudes de mesure"/>

        <!-- En-tête -->
        <Border Grid.Row="1" Padding="24,12,24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10"
                        Background="{StaticResource AsertiNavyBrush}"
                        Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="DataHistogram24" FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Incertitudes de mesure"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="Coefficients A/B par appareil, rubidium et mode de raccordement"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Padding="10,6" CornerRadius="12"
                            Margin="0,0,12,0"
                            Background="#FFDCFCE7"
                            Visibility="{Binding EditionDebloquee, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="CheckmarkCircle20" FontSize="14"
                                           Foreground="#FF16A34A" Margin="0,0,6,0"/>
                            <TextBlock Text="Édition débloquée" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FF166534"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Modifier les valeurs"
                            Command="{Binding ModifierCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="16,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Paramètres globaux -->
        <Border Grid.Row="2" Margin="24,0,24,12"
                Background="White"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0">
                    <ui:SymbolIcon Symbol="Options24" FontSize="18"
                                   Foreground="{StaticResource AsertiOrangeBrush}"
                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Paramètres globaux"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource AsertiNavyBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="NB. MES. ACCR." Style="{StaticResource FormLabelStyle}"/>
                    <ui:TextBox Text="{Binding ParametresGlobaux.NbMesAccr}"
                                IsEnabled="{Binding EditionDebloquee}"
                                Padding="8,6"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="TEMPS MES. ACCR. (s)" Style="{StaticResource FormLabelStyle}"/>
                    <ui:TextBox Text="{Binding ParametresGlobaux.TempsMesAccrSec}"
                                IsEnabled="{Binding EditionDebloquee}"
                                Padding="8,6"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="INCERT. ACCR." Style="{StaticResource FormLabelStyle}"/>
                    <ui:TextBox Text="{Binding ParametresGlobaux.IncertAccr, StringFormat={}{0:E3}}"
                                IsEnabled="{Binding EditionDebloquee}"
                                Padding="8,6"/>
                </StackPanel>

                <!-- Sélecteur de rubidium -->
                <StackPanel Grid.Column="4" Margin="24,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="RUBIDIUM ACTIF" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Rubidiums}"
                              SelectedItem="{Binding RubidiumSelectionne}"
                              DisplayMemberPath="Designation"
                              Width="200"
                              Padding="10,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Contenu principal avec tabs -->
        <TabControl Grid.Row="3" Margin="24,0,24,0"
                    Background="Transparent"
                    BorderThickness="0">
            <!-- Tab Fréquence -->
            <TabItem Header="Fréquence">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource FormSectionStyle}" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Fréquences fixes" Style="{StaticResource GridSectionTitle}"/>
                                <DataGrid ItemsSource="{Binding FreqFixes}" MinHeight="160">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Plage" Binding="{Binding Plage}" Width="*"/>
                                        <DataGridTextColumn Header="Raccord" Binding="{Binding Raccord}" Width="Auto"/>
                                        <DataGridTextColumn Header="a" Binding="{Binding CoeffA, StringFormat={}{0:E2}}" Width="Auto"/>
                                        <DataGridTextColumn Header="b" Binding="{Binding CoeffB, StringFormat={}{0:E2}}" Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource FormSectionStyle}" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Stanford SR620" Style="{StaticResource GridSectionTitle}"/>
                                <DataGrid ItemsSource="{Binding FreqStanford}" MinHeight="160">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Plage" Binding="{Binding Plage}" Width="*"/>
                                        <DataGridTextColumn Header="Raccord" Binding="{Binding Raccord}" Width="Auto"/>
                                        <DataGridTextColumn Header="a" Binding="{Binding CoeffA, StringFormat={}{0:E2}}" Width="Auto"/>
                                        <DataGridTextColumn Header="b" Binding="{Binding CoeffB, StringFormat={}{0:E2}}" Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource FormSectionStyle}" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Racal-Dana 1996" Style="{StaticResource GridSectionTitle}"/>
                                <DataGrid ItemsSource="{Binding FreqRacal}" MinHeight="160">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Plage" Binding="{Binding Plage}" Width="*"/>
                                        <DataGridTextColumn Header="Raccord" Binding="{Binding Raccord}" Width="Auto"/>
                                        <DataGridTextColumn Header="a" Binding="{Binding CoeffA, StringFormat={}{0:E2}}" Width="Auto"/>
                                        <DataGridTextColumn Header="b" Binding="{Binding CoeffB, StringFormat={}{0:E2}}" Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource FormSectionStyle}" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="EIP 545" Style="{StaticResource GridSectionTitle}"/>
                                <DataGrid ItemsSource="{Binding FreqEip}" MinHeight="160">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Plage" Binding="{Binding Plage}" Width="*"/>
                                        <DataGridTextColumn Header="Raccord" Binding="{Binding Raccord}" Width="Auto"/>
                                        <DataGridTextColumn Header="a" Binding="{Binding CoeffA, StringFormat={}{0:E2}}" Width="Auto"/>
                                        <DataGridTextColumn Header="b" Binding="{Binding CoeffB, StringFormat={}{0:E2}}" Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Tab Stabilité -->
            <TabItem Header="Stabilité">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource FormSectionStyle}" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Fréquences fixes" Style="{StaticResource GridSectionTitle}"/>
                                <DataGrid ItemsSource="{Binding StabFixes}" MinHeight="220">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Temps de mesure" Binding="{Binding TempsDeMesure}" Width="*"/>
                                        <DataGridTextColumn Header="Valeur" Binding="{Binding Valeur, StringFormat={}{0:E2}}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource FormSectionStyle}" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Stanford SR620" Style="{StaticResource GridSectionTitle}"/>
                                <DataGrid ItemsSource="{Binding StabStanford}" MinHeight="220">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Temps de mesure" Binding="{Binding TempsDeMesure}" Width="*"/>
                                        <DataGridTextColumn Header="Valeur" Binding="{Binding Valeur, StringFormat={}{0:E2}}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Style="{StaticResource FormSectionStyle}" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Racal-Dana 1996" Style="{StaticResource GridSectionTitle}"/>
                                <DataGrid ItemsSource="{Binding StabRacal}" MinHeight="220">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Temps de mesure" Binding="{Binding TempsDeMesure}" Width="*"/>
                                        <DataGridTextColumn Header="Valeur" Binding="{Binding Valeur, StringFormat={}{0:E2}}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Tab Autres mesures -->
            <TabItem Header="Autres mesures">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,0">
                    <StackPanel>
                        <Border Style="{StaticResource FormSectionStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Intervalle de temps" Style="{StaticResource GridSectionTitle}"/>
                                <DataGrid ItemsSource="{Binding AutresIntervalle}" MinHeight="80">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Libellé" Binding="{Binding Libelle}" Width="*"/>
                                        <DataGridTextColumn Header="a" Binding="{Binding CoeffA, StringFormat={}{0:E2}}" Width="150"/>
                                        <DataGridTextColumn Header="b" Binding="{Binding CoeffB, StringFormat={}{0:E2}}" Width="150"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource FormSectionStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Tachymétrie par contacts" Style="{StaticResource GridSectionTitle}"/>
                                <DataGrid ItemsSource="{Binding AutresTachyContact}" MinHeight="80">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Libellé" Binding="{Binding Libelle}" Width="*"/>
                                        <DataGridTextColumn Header="a" Binding="{Binding CoeffA, StringFormat={}{0:E2}}" Width="150"/>
                                        <DataGridTextColumn Header="b" Binding="{Binding CoeffB, StringFormat={}{0:E2}}" Width="150"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource FormSectionStyle}" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Stroboscope" Style="{StaticResource GridSectionTitle}"/>
                                <DataGrid ItemsSource="{Binding AutresStroboscope}" MinHeight="80">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Libellé" Binding="{Binding Libelle}" Width="*"/>
                                        <DataGridTextColumn Header="a" Binding="{Binding CoeffA, StringFormat={}{0:E2}}" Width="150"/>
                                        <DataGridTextColumn Header="b" Binding="{Binding CoeffB, StringFormat={}{0:E2}}" Width="150"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="4"
                Padding="24,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Button Content="Fermer"
                    Command="{Binding FermerCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Right"
                    MinWidth="140"/>
        </Border>
    </Grid>
</ui:FluentWindow>
