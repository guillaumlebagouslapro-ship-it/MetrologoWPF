<ui:FluentWindow x:Class="Metrologo.Views.InfoMdpGenereDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Mot de passe généré"
        Height="420" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Icon="/Resources/logo.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Mot de passe généré" ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/logo.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Margin="32,16,32,8" VerticalAlignment="Center">

            <Border Width="60" Height="60" CornerRadius="14"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,14"
                    Background="{StaticResource AsertiOrangeBrush}">
                <ui:SymbolIcon Symbol="Key24" FontSize="30"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
            </Border>

            <TextBlock x:Name="TbTitre"
                       Text="Mot de passe généré"
                       FontSize="20" FontWeight="Bold"
                       TextAlignment="Center"
                       Foreground="{StaticResource AsertiNavyBrush}"/>

            <Border CornerRadius="8" Padding="14,10" Margin="0,16,0,16"
                    Background="#FFFFF7ED"
                    BorderBrush="#FFFED7AA"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Warning24" FontSize="16"
                                   Foreground="{StaticResource AsertiOrangeBrush}"
                                   Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Ce mot de passe ne sera affiché qu'une seule fois — note-le ou copie-le maintenant."
                               FontSize="12" TextWrapping="Wrap"
                               Foreground="#FF7C2D12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                           Text="IDENTIFIANT" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource AsertiOrangeBrush}"
                           Margin="0,0,0,4"/>
                <Border Grid.Row="1" Grid.Column="0"
                        Padding="12,8" CornerRadius="6"
                        Background="{DynamicResource LayerFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="TbLogin" FontFamily="Cascadia Mono, Consolas"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                </Border>
                <Button Grid.Row="1" Grid.Column="1"
                        Click="OnCopierLogin"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="10,8" Margin="6,0,0,0"
                        ToolTip="Copier l'identifiant">
                    <ui:SymbolIcon Symbol="Copy24" FontSize="14"/>
                </Button>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                           Text="MOT DE PASSE" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource AsertiOrangeBrush}"
                           Margin="0,0,0,4"/>
                <Border Grid.Row="1" Grid.Column="0"
                        Padding="12,8" CornerRadius="6"
                        Background="{DynamicResource LayerFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="TbMdp" FontFamily="Cascadia Mono, Consolas"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                </Border>
                <Button Grid.Row="1" Grid.Column="1"
                        Click="OnCopierMdp"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="10,8" Margin="6,0,0,0"
                        ToolTip="Copier le mot de passe">
                    <ui:SymbolIcon Symbol="Copy24" FontSize="14"/>
                </Button>
            </Grid>
        </StackPanel>

        <Border Grid.Row="2" Padding="20,12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <Button Content="J'ai noté ce mot de passe"
                    Click="OnFermer"
                    IsDefault="True"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Stretch"/>
        </Border>
    </Grid>
</ui:FluentWindow>
