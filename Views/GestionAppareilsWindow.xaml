<ui:FluentWindow x:Class="Metrologo.Views.GestionAppareilsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Gérer les appareils"
        Height="720" Width="1040"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Gérer les appareils du catalogue"/>

        <!-- Bandeau intro -->
        <Border Grid.Row="1" CornerRadius="10" Padding="20,16" Margin="20,16,20,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="ZONE ADMINISTRATEUR" FontSize="11" FontWeight="Bold"
                               Margin="0,0,0,4">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{StaticResource AsertiOrangeLightColor}"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Gestion du catalogue d'appareils"
                               FontSize="20" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Modifier ou supprimer les modèles enregistrés par les utilisateurs."
                               FontSize="12" Margin="0,4,0,0">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="White" Opacity="0.78"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>
                <Border Grid.Column="1" CornerRadius="20" Padding="14,8"
                        Background="#FFDCFCE7" VerticalAlignment="Center">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#FF16A34A">
                        <Run Text="{Binding NbModeles, Mode=OneWay}"/>
                        <Run Text=" modèle(s)"/>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <!-- Chemin du catalogue -->
        <Border Grid.Row="2" CornerRadius="8" Padding="14,10" Margin="20,0,20,12"
                Background="White"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Grid.Column="0" Symbol="Folder24" FontSize="18"
                               Foreground="{StaticResource AsertiOrangeBrush}"
                               Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding CheminCatalogue}"
                           FontFamily="Cascadia Mono, Consolas" FontSize="11"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Button Grid.Column="2"
                        Command="{Binding OuvrirDossierCatalogueCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,6"
                        MinWidth="130">
                    <TextBlock Text="Ouvrir le dossier" FontSize="11"/>
                </Button>
            </Grid>
        </Border>

        <!-- Liste des modèles -->
        <Border Grid.Row="3" CornerRadius="10" Padding="0" Margin="20,0,20,12"
                Background="White"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid>
                <!-- État vide -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding CatalogueVide, Converter={StaticResource BoolToVis}}">
                    <ui:SymbolIcon Symbol="BoxDismiss24" FontSize="48"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Aucun modèle dans le catalogue"
                               FontSize="15" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="Ouvrez APPAREILS depuis l'accueil pour scanner et enregistrer un nouvel appareil."
                               FontSize="12" TextWrapping="Wrap" MaxWidth="400"
                               TextAlignment="Center" Margin="0,6,0,0"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                </StackPanel>

                <!-- Liste -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Modeles}" Padding="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="14,12" Margin="0,0,0,6"
                                        Background="#FFF9FAFB"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AsertiNavyBrush}"
                                                       Text="{Binding Nom}"/>
                                            <TextBlock FontSize="11" Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                <Run Text="IDN : "/>
                                                <Run Text="{Binding FabricantIdn, Mode=OneWay}"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding ModeleIdn, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="10" Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                                <Run Text="Créé le "/>
                                                <Run Text="{Binding DateCreation, StringFormat='dd/MM/yyyy', Mode=OneWay}"/>
                                                <Run Text=" par "/>
                                                <Run Text="{Binding CreePar, Mode=OneWay}"/>
                                                <Run Text=" · ID "/>
                                                <Run Text="{Binding Id, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Command="{Binding DataContext.ModifierModeleCommand,
                                                         RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="12,6" MinWidth="100" Margin="0,0,6,0">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Edit24" FontSize="12"
                                                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Modifier" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Grid.Column="2"
                                                Command="{Binding DataContext.SupprimerModeleCommand,
                                                         RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="12,6" MinWidth="100"
                                                Background="#FFFEE2E2"
                                                BorderBrush="#FFFCA5A5"
                                                BorderThickness="1"
                                                Foreground="#FF991B1B">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Delete24" FontSize="12"
                                                               Foreground="#FF991B1B"
                                                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Supprimer" FontSize="11"
                                                           Foreground="#FF991B1B"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Bouton Fermer -->
        <Border Grid.Row="4" Background="White"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="20,12">
            <Button Command="{Binding FermerCommand}"
                    HorizontalAlignment="Right"
                    Padding="20,8" MinWidth="100">
                <TextBlock Text="Fermer"/>
            </Button>
        </Border>
    </Grid>
</ui:FluentWindow>
