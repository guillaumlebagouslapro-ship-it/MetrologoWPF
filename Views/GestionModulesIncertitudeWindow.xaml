<ui:FluentWindow x:Class="Metrologo.Views.GestionModulesIncertitudeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Modules d'incertitude"
        Height="780" Width="1280"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <!-- Style monospace pour cellules numériques -->
        <Style x:Key="MonoCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
        </Style>

        <!-- Style item de la liste des modules (sidebar) -->
        <Style x:Key="ModuleItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ModuleItemTemplate">
            <Border CornerRadius="8" Padding="12,10" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="{Binding NumModule}" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="{Binding NomAffichage}" FontSize="11" Margin="0,2,0,0"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NomAffichage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Border Background="#FFE0E7FF" CornerRadius="6" Padding="6,1" Margin="0,0,4,0">
                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="#FF4338CA">
                                <Run Text="{Binding Lignes.Count, Mode=OneWay}"/>
                                <Run Text=" lignes"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Modules d'incertitude"/>

        <Border Grid.Row="1" CornerRadius="12" Padding="22,16" Margin="20,16,20,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="50" Height="50" CornerRadius="12"
                        Background="#33FFFFFF" Margin="0,0,16,0">
                    <ui:SymbolIcon Symbol="DataHistogram24" FontSize="26"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="ZONE ADMINISTRATEUR" FontSize="10" FontWeight="Bold" Margin="0,0,0,2">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{StaticResource AsertiOrangeLightColor}"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Modules d'incertitude" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Tableau Fonction × Temps × Plage de fréquence → Coefficients A et B"
                               FontSize="11" Margin="0,2,0,0">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="White" Opacity="0.78"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>

                <!-- Stats live -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#33FFFFFF" CornerRadius="10" Padding="12,8" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="{Binding NbTempsDistincts}" FontSize="22" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Temps de mesure" FontSize="10" Foreground="White" Opacity="0.78"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#33FFFFFF" CornerRadius="10" Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="{Binding NbLignes}" FontSize="22" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Lignes au total" FontSize="10" Foreground="White" Opacity="0.78"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="20,0,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Sélecteur de catégorie (= sous-dossier consulté). -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <ui:SymbolIcon Symbol="Folder24" FontSize="14"
                                       Foreground="{StaticResource AsertiNavyBrush}"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="CATÉGORIE" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource AsertiNavyBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ComboBox Grid.Row="1"
                              ItemsSource="{Binding CategoriesDisponibles}"
                              SelectedValue="{Binding TypeMesureSelectionne, Mode=TwoWay}"
                              SelectedValuePath="Type"
                              DisplayMemberPath="Libelle"
                              Padding="10,6"
                              Margin="0,0,0,14"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                        <ui:SymbolIcon Symbol="Apps24" FontSize="14"
                                       Foreground="{StaticResource AsertiOrangeBrush}"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="MODULES" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource AsertiOrangeBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ListBox Grid.Row="3" ItemsSource="{Binding Modules}"
                             SelectedItem="{Binding ModuleSelectionne, Mode=TwoWay}"
                             ItemTemplate="{StaticResource ModuleItemTemplate}"
                             ItemContainerStyle="{StaticResource ModuleItemStyle}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                    <StackPanel Grid.Row="4" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon Add24}"
                                       Content="Nouveau"
                                       Command="{Binding AjouterCommand}" Margin="0,0,6,0"/>
                            <ui:Button Appearance="Danger" Icon="{ui:SymbolIcon Delete24}"
                                       Content="Suppr."
                                       Command="{Binding SupprimerCommand}"/>
                        </StackPanel>
                        <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon Copy24}"
                                   Content="Copier vers..."
                                   ToolTip="Duplique ce module dans une autre catégorie (utile si applicable à plusieurs types de mesure)."
                                   HorizontalAlignment="Stretch"
                                   Command="{Binding CopierVersCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource AsertiNavyBrush}">
                                <Run Text="{Binding ModuleSelectionne.NumModule, FallbackValue='Aucun module'}"/>
                            </TextBlock>
                            <TextBlock FontSize="12" Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="{Binding ModuleSelectionne.NomAffichage}"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Grid.Row="1" Text="{Binding InfosFonctions}"
                               FontSize="11" Margin="0,4,0,12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

                    <DataGrid Grid.Row="2" x:Name="DgLignes"
                              ItemsSource="{Binding ModuleSelectionne.Lignes}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#FFF8FAFC"
                              RowBackground="White"
                              FontFamily="Segoe UI"
                              FontSize="12"
                              RowHeight="30"
                              ColumnHeaderHeight="36"
                              SelectionUnit="FullRow"
                              SelectionMode="Extended"
                              BorderThickness="0">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource AsertiNavyBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FFFEF3C7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridComboBoxColumn Header="Fonction"
                                                    SelectedItemBinding="{Binding Fonction, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="100">
                                <DataGridComboBoxColumn.ElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource"
                                                Value="{Binding DataContext.FonctionsDisponibles, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        <Setter Property="IsReadOnly" Value="True"/>
                                    </Style>
                                </DataGridComboBoxColumn.ElementStyle>
                                <DataGridComboBoxColumn.EditingElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource"
                                                Value="{Binding DataContext.FonctionsDisponibles, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </Style>
                                </DataGridComboBoxColumn.EditingElementStyle>
                            </DataGridComboBoxColumn>
                            <DataGridTextColumn Header="Temps (s)" Binding="{Binding TempsDeMesure}" Width="80"/>
                            <DataGridTextColumn Header="Borne basse (Hz)"
                                                Binding="{Binding BorneBasse, StringFormat=G}"
                                                Width="150"
                                                ElementStyle="{StaticResource MonoCell}"/>
                            <DataGridTextColumn Header="Borne haute (Hz)"
                                                Binding="{Binding BorneHaute, StringFormat=G}"
                                                Width="150"
                                                ElementStyle="{StaticResource MonoCell}"/>
                            <DataGridTextColumn Header="Dom 2 — basse"
                                                Binding="{Binding BorneBasseDomaine2, StringFormat=G}"
                                                Width="120"
                                                ElementStyle="{StaticResource MonoCell}"/>
                            <DataGridTextColumn Header="Dom 2 — haute"
                                                Binding="{Binding BorneHauteDomaine2, StringFormat=G}"
                                                Width="120"
                                                ElementStyle="{StaticResource MonoCell}"/>
                            <DataGridTextColumn Header="Condition 2"
                                                Binding="{Binding Condition2}"
                                                Width="110"/>
                            <DataGridTextColumn Header="Coeff A"
                                                Binding="{Binding IncertRelative, StringFormat='0.00E+00'}"
                                                Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MonoCell}">
                                        <Setter Property="Foreground" Value="#FF4338CA"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Coeff B"
                                                Binding="{Binding IncertAbsolue, StringFormat='0.00E+00'}"
                                                Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MonoCell}">
                                        <Setter Property="Foreground" Value="#FF991B1B"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
                        <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon Save24}"
                                   Content="Enregistrer"
                                   Command="{Binding EnregistrerCommand}" Margin="0,0,8,0"/>
                        <ui:Button Appearance="Caution" Icon="{ui:SymbolIcon Add24}"
                                   Content="Ajouter un temps de mesure"
                                   ToolTip="Crée automatiquement les 3 plages (basse / moyenne / haute) à remplir."
                                   Command="{Binding AjouterTrioCommand}" Margin="0,0,8,0"/>
                        <ui:Button Appearance="Danger" Icon="{ui:SymbolIcon Delete24}"
                                   Content="Suppr. lignes sélect."
                                   Command="{Binding SupprimerLignesCommand}"
                                   CommandParameter="{Binding ElementName=DgLignes, Path=SelectedItems}"
                                   Margin="0,0,8,0"/>
                        <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon ArrowSync24}"
                                   Content="Recharger"
                                   Command="{Binding RechargerCommand}" Margin="0,0,8,0"/>
                        <ui:Button Appearance="Secondary" Icon="{ui:SymbolIcon FolderOpen24}"
                                   Content="Dossier"
                                   Command="{Binding OuvrirDossierCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="20,8">
            <TextBlock Text="{Binding Statut}" FontSize="12"/>
        </Border>
    </Grid>
</ui:FluentWindow>
