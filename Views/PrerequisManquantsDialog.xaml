<ui:FluentWindow x:Class="Metrologo.Views.PrerequisManquantsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Prérequis manquants"
        Height="620" Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Icon="/Resources/logo.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Prérequis manquants" ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/logo.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Bandeau -->
        <Border Grid.Row="1" CornerRadius="10" Padding="20,16" Margin="20,16,20,12"
                Effect="{StaticResource BannerShadow}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FFB91C1C" Offset="0"/>
                    <GradientStop Color="#FFDC2626" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12"
                        Margin="0,0,16,0">
                    <Border.Background>
                        <SolidColorBrush Color="White" Opacity="0.22"/>
                    </Border.Background>
                    <ui:SymbolIcon Symbol="Warning24" FontSize="26"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="ENVIRONNEMENT INCOMPLET" FontSize="11" FontWeight="Bold"
                               Foreground="White" Opacity="0.85"/>
                    <TextBlock x:Name="TbTitre"
                               Text="Certains prérequis sont manquants sur ce poste"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Vérifie la liste ci-dessous et installe les composants manquants, ou continue en mode dégradé."
                               FontSize="12"
                               Foreground="White" Opacity="0.85"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Liste des prérequis manquants -->
        <ScrollViewer Grid.Row="2" Margin="20,0,20,12" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="LstPrerequis">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="10" Padding="16,14" Margin="0,0,0,10"
                                Background="White"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#FFFED7AA"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Critique}" Value="True">
                                            <Setter Property="BorderBrush" Value="#FFFCA5A5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                                        Margin="0,0,14,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFFFF7ED"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Critique}" Value="True">
                                                    <Setter Property="Background" Value="#FFFEE2E2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <ui:SymbolIcon FontSize="20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Setter Property="Symbol" Value="Warning24"/>
                                                <Setter Property="Foreground" Value="{StaticResource AsertiOrangeBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Critique}" Value="True">
                                                        <Setter Property="Symbol" Value="ErrorCircle24"/>
                                                        <Setter Property="Foreground" Value="#FFDC2626"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Nom}"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="{StaticResource AsertiNavyBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border CornerRadius="10" Padding="6,2" Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FFFEF3C7"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Critique}" Value="True">
                                                            <Setter Property="Background" Value="#FFFEE2E2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="9" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="RECOMMANDÉ"/>
                                                        <Setter Property="Foreground" Value="#FF92400E"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Critique}" Value="True">
                                                                <Setter Property="Text" Value="CRITIQUE"/>
                                                                <Setter Property="Foreground" Value="#FF991B1B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Detail}"
                                               FontSize="12" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding Impact}"
                                               FontSize="11" TextWrapping="Wrap"
                                               FontStyle="Italic"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                                    <!-- Lien de téléchargement (s'il existe) -->
                                    <TextBlock Margin="0,8,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LienTelechargement}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Hyperlink NavigateUri="{Binding LienTelechargement}"
                                                   RequestNavigate="OnHyperlink_RequestNavigate">
                                            <Run Text="Télécharger depuis le site officiel →"/>
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Boutons -->
        <Border Grid.Row="3" Padding="20,12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Quitter Metrologo"
                        Click="OnQuitter"
                        Style="{StaticResource SecondaryButtonStyle}"/>

                <Button Grid.Column="2"
                        Content="Continuer en mode dégradé"
                        Click="OnContinuer"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
