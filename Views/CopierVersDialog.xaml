<ui:FluentWindow x:Class="Metrologo.Views.CopierVersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Copier le module"
        Height="280" Width="480"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Copier le module"/>

        <StackPanel Grid.Row="1" Margin="24,16,24,0">
            <TextBlock x:Name="TbInfo"
                       TextWrapping="Wrap" FontSize="12" Margin="0,0,0,16" Opacity="0.85"/>

            <TextBlock Text="Catégorie cible" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox x:Name="CbCategorie"
                      DisplayMemberPath="Libelle"
                      Padding="10,6"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,24,16">
            <ui:Button Appearance="Secondary" Content="Annuler" Click="OnAnnuler" Margin="0,0,8,0"/>
            <ui:Button Appearance="Primary" Content="Copier" Click="OnValider"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
