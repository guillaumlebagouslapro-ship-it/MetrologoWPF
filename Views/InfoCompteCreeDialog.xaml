<ui:FluentWindow x:Class="Metrologo.Views.InfoCompteCreeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Compte créé"
        Height="380" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Compte créé"/>

        <StackPanel Grid.Row="1" Margin="24,16,24,0">
            <ui:InfoBar Severity="Warning" IsClosable="False" IsOpen="True"
                        Title="Mot de passe affiché une seule fois"
                        Message="Communiquez ce mot de passe à l'utilisateur. Il ne sera plus accessible après fermeture de cette fenêtre."
                        Margin="0,0,0,16"/>

            <TextBlock Text="Identifiant" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="TbLogin" Grid.Column="0" IsReadOnly="True" FontFamily="Consolas" FontSize="14"/>
                <ui:Button Grid.Column="1" Margin="8,0,0,0" Icon="{ui:SymbolIcon Copy24}"
                           Click="OnCopierLogin" ToolTip="Copier"/>
            </Grid>

            <TextBlock Text="Mot de passe initial" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="TbMdp" Grid.Column="0" IsReadOnly="True" FontFamily="Consolas" FontSize="14"/>
                <ui:Button Grid.Column="1" Margin="8,0,0,0" Icon="{ui:SymbolIcon Copy24}"
                           Click="OnCopierMdp" ToolTip="Copier"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,24,16">
            <ui:Button Appearance="Primary" Content="Fermer" Click="OnFermer"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
