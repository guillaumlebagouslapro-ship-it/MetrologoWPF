<ui:FluentWindow x:Class="Metrologo.Views.MtxBusyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Instance déjà lancée"
        Height="360" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Metrologo" ShowMaximize="False" ShowMinimize="False"/>

        <StackPanel Grid.Row="1" Margin="40,20,40,20" VerticalAlignment="Center">
            <Border Width="72" Height="72" CornerRadius="18"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,20">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.15"/>
                </Border.Background>
                <ui:SymbolIcon Symbol="Warning24" FontSize="40"
                               Foreground="{StaticResource AsertiOrangeBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="{Binding Titre}"
                       FontSize="20" FontWeight="Bold"
                       TextAlignment="Center"
                       Foreground="{StaticResource AsertiNavyBrush}"
                       Margin="0,0,0,10"/>
            <TextBlock Text="{Binding Message}"
                       FontSize="13"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="24,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Button Content="Fermer"
                    Command="{Binding AbandonnerCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True"
                    HorizontalAlignment="Right"
                    MinWidth="140"/>
        </Border>
    </Grid>
</ui:FluentWindow>
