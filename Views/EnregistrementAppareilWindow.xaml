<ui:FluentWindow x:Class="Metrologo.Views.EnregistrementAppareilWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Metrologo.ViewModels"
        Title="Enregistrer un appareil"
        Height="820" Width="760"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Icon="/Resources/logo.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Enregistrer un appareil au catalogue">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/logo.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Bandeau intro avec bouton d'aide -->
        <Border Grid.Row="1" CornerRadius="10" Padding="20,16" Margin="20,16,20,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="NOUVEL APPAREIL DÉTECTÉ" FontSize="11" FontWeight="Bold"
                               Margin="0,0,0,4">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{StaticResource AsertiOrangeLightColor}"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Ajouter au catalogue local"
                               FontSize="20" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock FontSize="12" Margin="0,4,0,0" FontFamily="Cascadia Mono, Consolas">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="White" Opacity="0.78"/>
                        </TextBlock.Foreground>
                        <Run Text="IDN : "/>
                        <Run Text="{Binding IdnDetecte, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Bouton "?" : ouvre la fenêtre d'aide sur les champs de saisie -->

                <Button Grid.Column="1"
                        Click="OnOuvrirAide"
                        VerticalAlignment="Top"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="0"
                        Background="Transparent"
                        ToolTip="Aide : que dois-je saisir ici ?">
                    <Border Width="36" Height="36" CornerRadius="18"
                            Background="#FF3B82F6"
                            BorderBrush="#FF1E40AF"
                            BorderThickness="2">
                        <TextBlock Text="?" FontSize="20" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Button>
            </Grid>
        </Border>

        <!-- Formulaire -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20,0,20,0">
            <StackPanel>

                <!-- Copier les réglages d'un modèle existant (ex. 53230A -> 53220A) -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Copier les réglages d'un modèle existant" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Recopie toutes les commandes (init, mesure, gates, intervalle, voies, réglages) du modèle choisi SANS toucher à l'identité ci-dessous. Pratique pour créer un 53220A à partir d'un 53230A : réglages identiques, fiche distincte."
                                   FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding ModelesPourCopie}"
                                      SelectedItem="{Binding ModeleSourceCopie, Mode=TwoWay}"
                                      DisplayMemberPath="Nom"
                                      Padding="10,6"/>
                            <Button Grid.Column="2"
                                    Content="Copier les réglages"
                                    Command="{Binding CopierReglagesDepuisSourceCommand}"
                                    Padding="14,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Identification -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Identification" Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Text="NOM AFFICHÉ" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,6" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MOTIF FABRICANT (IDN)" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding FabricantIdn, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Cascadia Mono, Consolas" Padding="10,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="MOTIF MODÈLE (IDN)" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding ModeleIdn, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Cascadia Mono, Consolas" Padding="10,6"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Servent à reconnaître l'appareil lors d'un futur scan. Le MODÈLE doit correspondre EXACTEMENT (ex. « 53220A » ≠ « 53230A ») ; le fabricant est tolérant (« contient »). Insensible à la casse."
                                   FontSize="10" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Commandes de base (init, mesure, gate), valeurs par défaut OK pour la plupart des appareils SCPI -->

                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Commandes de base"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock TextWrapping="Wrap"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,10">
                            <Run Text="Valeurs SCPI standard pré-remplies. Pour la plupart des fréquencemètres modernes, rien à changer. Consulte la doc de ton appareil si les mesures ne partent pas."/>
                        </TextBlock>

                        <TextBlock Text="CHAÎNE D'INITIALISATION (envoyée au début de chaque mesure)"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <ui:TextBox Text="{Binding ChaineInit, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="*RST;*CLS"
                                    FontFamily="Cascadia Mono, Consolas"
                                    Padding="8,4" Margin="0,0,0,12"/>

                        <TextBlock Text="COMMANDE DE MESURE (déclenche et retourne la valeur)"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <ui:TextBox Text="{Binding ExeMesure, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText=":READ?"
                                    FontFamily="Cascadia Mono, Consolas"
                                    Padding="8,4" Margin="0,0,0,12"/>

                        <TextBlock Text="COMMANDE DE GATE (template, {0} = temps en secondes)"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <ui:TextBox Text="{Binding CommandeGate, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText=":FREQ:APER {0}"
                                    FontFamily="Cascadia Mono, Consolas"
                                    Padding="8,4" Margin="0,0,0,12"/>

                        <TextBlock Text="COMMANDE MESURE MULTIPLE (optionnel, {N} = nombre de mesures)"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <TextBlock Text="Si renseigné, l'instrument fait les N mesures en interne et les retourne en CSV — beaucoup plus rapide pour les gates courtes. Vide = fallback automatique sur :FETCh? boucle."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding CommandeMesureMultiple, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText=":SAMP:COUN {N};:READ:ARR? {N}"
                                    FontFamily="Cascadia Mono, Consolas"
                                    Padding="8,4" Margin="0,0,0,12"/>

                        <TextBlock Text="COMMANDE FETCH BLOQUANTE (optionnel)"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <TextBlock Text="Si renseigné, l'orchestrator l'utilise au lieu de :FETCh? + Task.Delay. La commande doit bloquer jusqu'à ce qu'une nouvelle mesure soit dispo (sinon doublons). Vide = mode :FETCh? avec délai automatique."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding CommandeFetchFresh, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText=":DATA:FRESh:FREQ?"
                                    FontFamily="Cascadia Mono, Consolas"
                                    Padding="8,4" Margin="0,0,0,12"/>

                        <CheckBox Content="Mode rapide (:INIT:CONT ON + :FETCh?)"
                                  IsChecked="{Binding ModeRapideActif, Mode=TwoWay}"
                                  Margin="0,0,0,2"/>
                        <TextBlock Text="⚠ Compteurs MODERNES (53220A / 53230A...) : laisser DÉCOCHÉ — sinon erreurs SCPI -113 / -230 / -420. À cocher uniquement pour un 53131A (accélère via :FETCh?)."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="TEMPS DE PORTE DISPONIBLES (cochez ceux supportés par l'appareil)"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <ItemsControl ItemsSource="{Binding GatesOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Libelle}"
                                              IsChecked="{Binding EstCoche, Mode=TwoWay}"
                                              MinWidth="78"
                                              Margin="0,4,12,4"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Réglages fréquencemètre : formulaire structuré (voies A, B, C + modes) -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Réglages fréquencemètre"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock TextWrapping="Wrap"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,14">
                            <Run Text="Remplis uniquement les commandes SCPI dont ton appareil a besoin."/>
                            <LineBreak/>
                            <Run Text="Tout champ laissé vide sera automatiquement masqué dans la fenêtre Configuration."/>
                            <LineBreak/>
                            <Run Text="Pour le Trigger, le template doit contenir {0} à l'emplacement de la valeur en volts."/>
                        </TextBlock>

                        <!-- ============ Sélecteur : nombre de voies de l'appareil ============ -->
                        <Border Background="#FFEFF6FF" BorderBrush="#FFBFDBFE" BorderThickness="1"
                                CornerRadius="6" Padding="14,10" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="NOMBRE DE VOIES DE L'APPAREIL"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource AsertiNavyBrush}"
                                           Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton GroupName="NbVoies"
                                                 Content="1 voie"
                                                 IsChecked="{Binding IsUneVoie, Mode=TwoWay}"
                                                 Margin="0,0,18,0"
                                                 ToolTip="Appareil mono-voie. Seule la VOIE A sera affichée."/>
                                    <RadioButton GroupName="NbVoies"
                                                 Content="2 voies (A + B)"
                                                 IsChecked="{Binding IsDeuxVoies, Mode=TwoWay}"
                                                 Margin="0,0,18,0"
                                                 ToolTip="Cas standard (53131A, 53230A). VOIE A et VOIE B affichées."/>
                                    <RadioButton GroupName="NbVoies"
                                                 Content="3 voies (A + B + C HF)"
                                                 IsChecked="{Binding IsTroisVoies, Mode=TwoWay}"
                                                 ToolTip="Appareil avec une voie C haute fréquence supplémentaire."/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ============ Voie A ============ -->
                        <Border BorderBrush="{StaticResource AsertiNavyLightBrush}"
                                BorderThickness="0,0,0,2"
                                Margin="0,0,0,8">
                            <TextBlock Text="VOIE A / CANAL 1"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource AsertiNavyBrush}"
                                       Margin="0,0,0,6"/>
                        </Border>

                        <Grid Margin="0,4,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Impédance"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="0" Grid.Column="1"
                                        Text="{Binding ImpedanceA50, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="50 Ω → :INP1:IMP 50"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                            <ui:TextBox Grid.Row="0" Grid.Column="3"
                                        Text="{Binding ImpedanceA1M, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="1 MΩ → :INP1:IMP 1E6"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Couplage"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="1" Grid.Column="1"
                                        Text="{Binding CouplageAAc, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="AC → :INP1:COUP AC"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                            <ui:TextBox Grid.Row="1" Grid.Column="3"
                                        Text="{Binding CouplageADc, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="DC → :INP1:COUP DC"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Filtre"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="2" Grid.Column="1"
                                        Text="{Binding FiltreAOn, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ON → :INP1:FILT ON"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                            <ui:TextBox Grid.Row="2" Grid.Column="3"
                                        Text="{Binding FiltreAOff, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="OFF → :INP1:FILT OFF"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                        </Grid>

                        <TextBlock Text="Trigger (template, {0} = valeur en volts)"
                                   FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding TriggerA, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText=":SENS:EVEN1:LEV {0}"
                                    FontFamily="Cascadia Mono, Consolas"
                                    Padding="8,4" Margin="0,0,0,16"/>

                        <!-- ============ Voie B (visible si NbVoies >= 2) ============ -->
                        <StackPanel Visibility="{Binding ShowVoieB, Converter={StaticResource BoolToVis}}">
                        <Border BorderBrush="{StaticResource AsertiNavyLightBrush}"
                                BorderThickness="0,0,0,2"
                                Margin="0,0,0,8">
                            <TextBlock Text="VOIE B / CANAL 2"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource AsertiNavyBrush}"
                                       Margin="0,0,0,6"/>
                        </Border>

                        <Grid Margin="0,4,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Impédance"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="0" Grid.Column="1"
                                        Text="{Binding ImpedanceB50, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="50 Ω → :INP2:IMP 50"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                            <ui:TextBox Grid.Row="0" Grid.Column="3"
                                        Text="{Binding ImpedanceB1M, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="1 MΩ → :INP2:IMP 1E6"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Couplage"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="1" Grid.Column="1"
                                        Text="{Binding CouplageBAc, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="AC → :INP2:COUP AC"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                            <ui:TextBox Grid.Row="1" Grid.Column="3"
                                        Text="{Binding CouplageBDc, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="DC → :INP2:COUP DC"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Filtre"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="2" Grid.Column="1"
                                        Text="{Binding FiltreBOn, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ON → :INP2:FILT ON"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                            <ui:TextBox Grid.Row="2" Grid.Column="3"
                                        Text="{Binding FiltreBOff, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="OFF → :INP2:FILT OFF"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                        </Grid>

                        <TextBlock Text="Trigger (template, {0} = valeur en volts)"
                                   FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding TriggerB, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText=":SENS:EVEN2:LEV {0}"
                                    FontFamily="Cascadia Mono, Consolas"
                                    Padding="8,4" Margin="0,0,0,16"/>
                        </StackPanel>
                        <!-- ============ Fin Voie B ============ -->

                        <!-- ============ Voie C (visible si NbVoies >= 3) ============ -->
                        <StackPanel Visibility="{Binding ShowVoieC, Converter={StaticResource BoolToVis}}">
                        <Border BorderBrush="{StaticResource AsertiNavyLightBrush}"
                                BorderThickness="0,0,0,2"
                                Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="VOIE C / CANAL 3"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource AsertiNavyBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="(voie HF haute fréquence)"
                                           FontSize="10" FontStyle="Italic"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="8,0,0,6"
                                           VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,4,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Impédance"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="0" Grid.Column="1"
                                        Text="{Binding ImpedanceC50, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="50 Ω → :INP3:IMP 50"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                            <ui:TextBox Grid.Row="0" Grid.Column="3"
                                        Text="{Binding ImpedanceC1M, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="1 MΩ → :INP3:IMP 1E6"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Couplage"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="1" Grid.Column="1"
                                        Text="{Binding CouplageCAc, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="AC → :INP3:COUP AC"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                            <ui:TextBox Grid.Row="1" Grid.Column="3"
                                        Text="{Binding CouplageCDc, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="DC → :INP3:COUP DC"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Filtre"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="2" Grid.Column="1"
                                        Text="{Binding FiltreCOn, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ON → :INP3:FILT ON"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                            <ui:TextBox Grid.Row="2" Grid.Column="3"
                                        Text="{Binding FiltreCOff, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="OFF → :INP3:FILT OFF"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                        </Grid>

                        <TextBlock Text="Trigger (template, {0} = valeur en volts)"
                                   FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding TriggerC, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText=":SENS:EVEN3:LEV {0}"
                                    FontFamily="Cascadia Mono, Consolas"
                                    Padding="8,4" Margin="0,0,0,16"/>
                        </StackPanel>
                        <!-- ============ Fin Voie C ============ -->

                        <!-- ============ Modes de mesure ============ -->
                        <Border BorderBrush="{StaticResource AsertiNavyLightBrush}"
                                BorderThickness="0,0,0,2"
                                Margin="0,0,0,8">
                            <TextBlock Text="MODES DE MESURE"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource AsertiNavyBrush}"
                                       Margin="0,0,0,6"/>
                        </Border>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode FREQ Voie A"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="0" Grid.Column="1"
                                        Text="{Binding ModeFreqA, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText=":FUNC &quot;FREQ 1&quot;"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Mode FREQ Voie B"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Margin="0,0,12,6"
                                       Visibility="{Binding ShowVoieB, Converter={StaticResource BoolToVis}}"/>
                            <ui:TextBox Grid.Row="1" Grid.Column="1"
                                        Text="{Binding ModeFreqB, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText=":FUNC &quot;FREQ 2&quot;"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"
                                        Visibility="{Binding ShowVoieB, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Mode FREQ Voie C"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Margin="0,0,12,6"
                                       Visibility="{Binding ShowVoieC, Converter={StaticResource BoolToVis}}"/>
                            <ui:TextBox Grid.Row="2" Grid.Column="1"
                                        Text="{Binding ModeFreqC, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText=":FUNC &quot;FREQ 3&quot; (optionnel)"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"
                                        Visibility="{Binding ShowVoieC, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Mode TIAB"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="3" Grid.Column="1"
                                        Text="{Binding ModeTiab, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText=":FUNC &quot;TINT 1,2&quot;"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- =================== RÉSOLUTION (auto, caché user) =================== -->
                <Border Background="White"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Résolution"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="Mode de calcul interne du compteur. Sélectionné automatiquement selon le type de mesure (CONT pour Stabilité, AUTO sinon) — invisible côté utilisateur."
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="AUTO"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="0" Grid.Column="1"
                                        Text="{Binding ResolutionAuto, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText=":SENS:FREQ:MODE AUTO"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="RECIPROCAL"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="1" Grid.Column="1"
                                        Text="{Binding ResolutionRecip, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText=":SENS:FREQ:MODE RECIPROCAL (optionnel)"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="CONT"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="2" Grid.Column="1"
                                        Text="{Binding ResolutionCont, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText=":SENS:FREQ:MODE CONT (pour Stabilité / Allan deviation)"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- =================== RÉFÉRENCE (choix user) =================== -->
                <Border Background="White"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Référence (base de temps)"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="Source de la base de temps : oscillateur interne (TCXO/OCXO) ou référence externe 10 MHz (rubidium, GPS…). L'utilisateur peut le choisir dans la fenêtre Configuration."
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="INT (interne)"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="0" Grid.Column="1"
                                        Text="{Binding RefInt, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText=":ROSC:SOUR INT"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="EXT 10 MHz"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="1" Grid.Column="1"
                                        Text="{Binding RefExt, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText=":ROSC:SOUR EXT"
                                        FontFamily="Cascadia Mono, Consolas"
                                        Padding="8,4" Margin="0,0,0,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ===== Intervalle de temps : templates SCPI propres à l'appareil ===== -->
                <Border Background="White"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Intervalle de temps"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="Commandes SCPI utilisées par le panneau « intervalle de temps » de la fenêtre Configuration (quand on décoche l'init manuelle). Laisse décoché si l'appareil ne gère pas l'intervalle : le panneau n'apparaîtra pas et aucune commande ne sera envoyée."
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox Content="Cet appareil gère l'intervalle de temps"
                                      IsChecked="{Binding IntervalleActif}"
                                      FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Command="{Binding RemplirIntervalleDefautCommand}"
                                    Content="Pré-remplir (53230A)"
                                    Margin="16,0,0,0" Padding="10,4"/>
                        </StackPanel>

                        <TextBlock Text="Placeholders remplis automatiquement : {V}=voie (1/2), {C}=couplage (AC/DC), {Z}=impédance (50/1E6), {S}=seuil (V), {P}=pente (POS/NEG), {T}=hold-off (s). Plusieurs commandes peuvent être chaînées par « ;: »."
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Config 1 voie"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="0" Grid.Column="1"
                                        Text="{Binding IntervConf1Voie, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ex: CONF:TINT (@1)"
                                        FontFamily="Cascadia Mono, Consolas" Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Config 2 voies"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="1" Grid.Column="1"
                                        Text="{Binding IntervConf2Voies, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ex: CONF:TINT (@1),(@2)"
                                        FontFamily="Cascadia Mono, Consolas" Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Couplage"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="2" Grid.Column="1"
                                        Text="{Binding IntervCmdCouplage, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ex: INP{V}:COUP {C}"
                                        FontFamily="Cascadia Mono, Consolas" Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Impédance"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="3" Grid.Column="1"
                                        Text="{Binding IntervCmdImpedance, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ex: INP{V}:IMP {Z}"
                                        FontFamily="Cascadia Mono, Consolas" Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Seuil départ"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="4" Grid.Column="1"
                                        Text="{Binding IntervCmdSeuilStart, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ex: INP{V}:LEV1 {S}"
                                        FontFamily="Cascadia Mono, Consolas" Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Pente départ"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="5" Grid.Column="1"
                                        Text="{Binding IntervCmdPenteStart, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ex: INP{V}:SLOP1 {P}"
                                        FontFamily="Cascadia Mono, Consolas" Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Seuil arrêt (1 voie)"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="6" Grid.Column="1"
                                        Text="{Binding IntervCmdSeuilStop1, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ex: INP1:LEV2 {S}"
                                        FontFamily="Cascadia Mono, Consolas" Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Pente arrêt (1 voie)"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="7" Grid.Column="1"
                                        Text="{Binding IntervCmdPenteStop1, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ex: INP1:SLOP2 {P}"
                                        FontFamily="Cascadia Mono, Consolas" Padding="8,4" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Hold-off (1 voie)"
                                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,6"/>
                            <ui:TextBox Grid.Row="8" Grid.Column="1"
                                        Text="{Binding IntervCmdHoldoff, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ex: TINT:GATE:SOUR ADV;:SENS:GATE:STOP:HOLD:SOUR TIME;:SENS:GATE:STOP:HOLD:TIME {T};:SENS:GATE:STOP:SOUR IMM"
                                        FontFamily="Cascadia Mono, Consolas" Padding="8,4" Margin="0,0,0,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Boutons bas -->
        <Border Grid.Row="3" Background="White"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="20,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding AnnulerCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="20,10" MinWidth="110" Margin="0,0,10,0">
                    <TextBlock Text="Annuler"/>
                </Button>
                <Button Command="{Binding EnregistrerCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="20,10" MinWidth="160">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Save24" FontSize="16" Foreground="White"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Enregistrer" Foreground="White" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
