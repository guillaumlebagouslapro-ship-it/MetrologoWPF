<ui:FluentWindow x:Class="Metrologo.Views.EnregistrementAppareilWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Enregistrer un appareil"
        Height="720" Width="720"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Enregistrer un appareil au catalogue"/>

        <!-- Bandeau intro -->
        <Border Grid.Row="1" CornerRadius="10" Padding="20,16" Margin="20,16,20,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock Text="NOUVEL APPAREIL DÉTECTÉ" FontSize="11" FontWeight="Bold"
                           Margin="0,0,0,4">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="{StaticResource AsertiOrangeLightColor}"/>
                    </TextBlock.Foreground>
                </TextBlock>
                <TextBlock Text="Ajouter au catalogue local"
                           FontSize="20" FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock FontSize="12" Margin="0,4,0,0" FontFamily="Cascadia Mono, Consolas">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="White" Opacity="0.78"/>
                    </TextBlock.Foreground>
                    <Run Text="IDN : "/>
                    <Run Text="{Binding IdnDetecte, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Formulaire -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20,0,20,0">
            <StackPanel>

                <!-- Identification -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Identification" Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Text="NOM AFFICHÉ" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,6" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MOTIF FABRICANT (IDN)" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding FabricantIdn, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Cascadia Mono, Consolas" Padding="10,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="MOTIF MODÈLE (IDN)" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding ModeleIdn, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Cascadia Mono, Consolas" Padding="10,6"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Ces motifs servent à reconnaître automatiquement l'appareil lors d'un futur scan (matching « contains » insensible à la casse)."
                                   FontSize="10" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Commandes SCPI -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Commandes SCPI / IEEE" Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Text="CHAÎNE D'INITIALISATION" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding ChaineInit, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Cascadia Mono, Consolas" Padding="10,6" Margin="0,0,0,12"/>

                        <TextBlock Text="CONFIGURATION D'ENTRÉE (optionnel)" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding ConfEntree, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Cascadia Mono, Consolas" Padding="10,6" Margin="0,0,0,12"/>

                        <TextBlock Text="COMMANDE DE MESURE (déclenche et retourne la valeur)"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding ExeMesure, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Cascadia Mono, Consolas" Padding="10,6" Margin="0,0,0,12"/>

                        <TextBlock Text="COMMANDE POUR PROGRAMMER LE GATE — utiliser {0} pour le temps en secondes"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding CommandeGate, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Cascadia Mono, Consolas" Padding="10,6" Margin="0,0,0,12"/>
                    </StackPanel>
                </Border>

                <!-- Terminateurs et SRQ -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Terminateurs et SRQ" Style="{StaticResource SectionTitleStyle}"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="TERM WRITE" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding TermWrite}" Padding="10,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="TERM READ" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding TermRead}" Padding="10,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="TAILLE HEADER" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding TailleHeader}" Padding="10,6"/>
                            </StackPanel>
                        </Grid>

                        <CheckBox Content="L'appareil gère le SRQ (Service Request)"
                                  IsChecked="{Binding GereSrq}" Margin="0,0,0,10"/>

                        <Grid Visibility="{Binding GereSrq, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="COMMANDE SRQ ON" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding SrqOn}"
                                         FontFamily="Cascadia Mono, Consolas" Padding="10,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="COMMANDE SRQ OFF" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Text="{Binding SrqOff}"
                                         FontFamily="Cascadia Mono, Consolas" Padding="10,6"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Options UI -->
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="Options pour la fenêtre de configuration"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Text="TEMPS DE PORTE DISPONIBLES (séparés par virgules)"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding GatesTexte, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,6" Margin="0,0,0,12"/>

                        <TextBlock Text="ENTRÉES / CANAUX (séparés par virgules, vide = pas de choix)"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EntreesTexte, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,6" Margin="0,0,0,12"/>

                        <TextBlock Text="COUPLAGES (séparés par virgules, vide = pas de choix)"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding CouplagesTexte, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,6"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Boutons bas -->
        <Border Grid.Row="3" Background="White"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="20,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding AnnulerCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="20,10" MinWidth="110" Margin="0,0,10,0">
                    <TextBlock Text="Annuler"/>
                </Button>
                <Button Command="{Binding EnregistrerCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="20,10" MinWidth="160">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Save24" FontSize="16" Foreground="White"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Enregistrer" Foreground="White" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
