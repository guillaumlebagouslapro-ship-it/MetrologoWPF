<UserControl x:Class="Metrologo.Views.SelectionScanModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="760" Margin="20">

            <TextBlock Text="DÉTECTION DES APPAREILS"
                       FontSize="12" FontWeight="Bold"
                       TextAlignment="Center"
                       Foreground="{StaticResource AsertiOrangeBrush}"
                       Margin="0,0,0,6"/>

            <TextBlock Text="Comment connecter les fréquencemètres ?"
                       FontSize="30" FontWeight="Bold"
                       TextAlignment="Center"
                       Foreground="{StaticResource AsertiNavyBrush}"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Scan automatique pour les compteurs modernes, ou adresses fixes pour les appareils anciens (EIP, Racal, Stanford) qui ne répondent pas à l'identification."
                       FontSize="13"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,40"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Scan GPIB -->
                <Button Grid.Column="0"
                        Command="{Binding ChoisirScanCommand}"
                        Cursor="Hand"
                        BorderThickness="0"
                        Padding="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b"
                                    CornerRadius="14"
                                    Background="White"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="100"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" CornerRadius="14,14,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="{StaticResource AsertiNavyDarkColor}" Offset="0"/>
                                                <GradientStop Color="{StaticResource AsertiNavyColor}" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid ClipToBounds="True">
                                            <Ellipse Width="180" Height="180"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                                     Margin="0,-50,-60,0" Opacity="0.15">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{StaticResource AsertiOrangeColor}"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <Border Width="68" Height="68" CornerRadius="16"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Margin="28,0,0,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="White" Opacity="0.18"/>
                                                </Border.Background>
                                                <ui:SymbolIcon Symbol="Search24" FontSize="34"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="28,20,28,28">
                                        <TextBlock Text="SCAN GPIB" FontSize="11" FontWeight="Bold"
                                                   Foreground="{StaticResource AsertiOrangeBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Détection automatique"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource AsertiNavyBrush}"/>
                                        <TextBlock Text="Le bus est balayé et les compteurs modernes (répondant à *IDN?) sont reconnus automatiquement."
                                                   FontSize="12" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,8,0,14"/>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="CheckmarkCircle20" FontSize="14"
                                                           Foreground="#FF16A34A" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Compteurs SCPI récents" FontSize="12"
                                                       Foreground="{StaticResource AsertiNavyBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                    <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Adresses fixes -->
                <Button Grid.Column="2"
                        Command="{Binding ChoisirAdressesFixesCommand}"
                        Cursor="Hand"
                        BorderThickness="0"
                        Padding="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b"
                                    CornerRadius="14"
                                    Background="White"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="100"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" CornerRadius="14,14,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="{StaticResource AsertiOrangeDarkColor}" Offset="0"/>
                                                <GradientStop Color="{StaticResource AsertiOrangeColor}" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid ClipToBounds="True">
                                            <Ellipse Width="180" Height="180"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                                     Margin="0,-50,-60,0" Opacity="0.15">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="White"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <Border Width="68" Height="68" CornerRadius="16"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Margin="28,0,0,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="White" Opacity="0.22"/>
                                                </Border.Background>
                                                <ui:SymbolIcon Symbol="Tag24" FontSize="34"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="28,20,28,28">
                                        <TextBlock Text="ADRESSES FIXES" FontSize="11" FontWeight="Bold"
                                                   Foreground="{StaticResource AsertiOrangeBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Sélection manuelle"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource AsertiNavyBrush}"/>
                                        <TextBlock Text="Vous choisissez l'appareil (EIP, Racal, Stanford) et son adresse GPIB. Pour les appareils anciens sans identification."
                                                   FontSize="12" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,8,0,14"/>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="CheckmarkCircle20" FontSize="14"
                                                           Foreground="#FF16A34A" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="EIP 545 · Racal-Dana 1996 · Stanford SR620" FontSize="12"
                                                       Foreground="{StaticResource AsertiNavyBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                    <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <ui:Button HorizontalAlignment="Center"
                       Margin="0,32,0,0"
                       Appearance="Secondary"
                       Cursor="Hand"
                       Command="{Binding RetourCommand}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="Retour au choix du poste" VerticalAlignment="Center"/>
                </StackPanel>
            </ui:Button>
        </StackPanel>
    </Grid>
</UserControl>
