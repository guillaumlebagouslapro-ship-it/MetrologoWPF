<ui:FluentWindow x:Class="Metrologo.Views.SaisieValFreqWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Saisie de fréquence"
        Height="380" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Saisie de fréquence" ShowMaximize="False"/>

        <Border Grid.Row="1" Padding="24,12,24,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10"
                        Background="{StaticResource AsertiNavyBrush}"
                        Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="Keyboard24" FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Titre}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="{Binding SousTitre}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Padding="24,0,24,16">
            <StackPanel>
                <Border Style="{StaticResource FormSectionStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding LibelleChamp}"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <ui:TextBox x:Name="txtValeur"
                                    Text="{Binding ValeurTexte, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="10000000"
                                    FontFamily="Cascadia Mono, Consolas"
                                    FontSize="18"
                                    Padding="12,10">
                            <ui:TextBox.Icon>
                                <ui:SymbolIcon Symbol="NumberSymbol24"/>
                            </ui:TextBox.Icon>
                        </ui:TextBox>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <ui:SymbolIcon Symbol="Info24" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Utilisez le point comme séparateur décimal."
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border CornerRadius="6" Padding="12,10"
                        Background="#FFFEE2E2"
                        BorderBrush="#FFFCA5A5"
                        BorderThickness="1"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Warning24" FontSize="16"
                                       Foreground="#FFDC2626"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding MessageErreur}"
                                   Foreground="#FF7F1D1D"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Padding="24,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Annuler"
                        Command="{Binding AnnulerCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>

                <Button Grid.Column="2"
                        Content="Valider"
                        Command="{Binding ValiderCommand}"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
