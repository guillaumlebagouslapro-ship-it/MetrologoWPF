<ui:FluentWindow x:Class="Metrologo.Views.SelValidationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Sélection du jeu de validation"
        Height="560" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Sélection du jeu de validation" ShowMaximize="False"/>

        <Border Grid.Row="1" Padding="24,12,24,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10"
                        Background="{StaticResource AsertiNavyBrush}"
                        Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Jeu de validation"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AsertiNavyBrush}"/>
                    <TextBlock Text="Choisissez le lot de données du classeur ValidationMetrologo.xlsx"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Padding="24,0,24,16">
            <Border Style="{StaticResource FormSectionStyle}">
                <StackPanel>
                    <TextBlock Text="JEUX DISPONIBLES" Style="{StaticResource FormLabelStyle}"/>
                    <ListBox ItemsSource="{Binding Validations}"
                             SelectedItem="{Binding ValidationSelectionnee, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,0,0,4"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="b"
                                                    CornerRadius="6"
                                                    Padding="14,10"
                                                    Background="White"
                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                    BorderThickness="1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeLightBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AsertiOrangeBrush}"/>
                                                    <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                                                    <Setter TargetName="b" Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.08"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Border Margin="0,12,0,0"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                            CornerRadius="6" Padding="12,10"
                            Background="#FFFEE2E2"
                            BorderBrush="#FFFCA5A5"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Warning24" FontSize="16"
                                           Foreground="#FFDC2626"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding MessageErreur}"
                                       Foreground="#FF7F1D1D"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.Row="3"
                Padding="24,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="Annuler"
                        Command="{Binding AnnulerCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Grid.Column="2"
                        Content="Valider"
                        Command="{Binding ValiderCommand}"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
