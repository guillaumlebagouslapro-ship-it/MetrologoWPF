<ui:FluentWindow x:Class="Metrologo.Views.MdpValidationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Authentification"
        Height="380" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Authentification" ShowMaximize="False"/>

        <StackPanel Grid.Row="1" Margin="32,16,32,24" VerticalAlignment="Center">
            <Border Width="56" Height="56" CornerRadius="14"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource AsertiOrangeColor}" Opacity="0.15"/>
                </Border.Background>
                <ui:SymbolIcon Symbol="LockClosed24" FontSize="28"
                               Foreground="{StaticResource AsertiOrangeBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="{Binding Titre}"
                       FontSize="20" FontWeight="Bold"
                       TextAlignment="Center"
                       Foreground="{StaticResource AsertiNavyBrush}"/>
            <TextBlock Text="{Binding SousTitre}"
                       FontSize="12"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,4,0,20"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

            <TextBlock Text="MOT DE PASSE" Style="{StaticResource FormLabelStyle}"/>
            <ui:PasswordBox x:Name="txtMdp"
                            PlaceholderText="••••••"
                            Padding="10,8"
                            Margin="0,0,0,8">
                <ui:PasswordBox.Icon>
                    <ui:SymbolIcon Symbol="LockClosed24"/>
                </ui:PasswordBox.Icon>
            </ui:PasswordBox>

            <Border CornerRadius="6" Padding="10,8"
                    Background="#FFFEE2E2"
                    BorderBrush="#FFFCA5A5"
                    BorderThickness="1"
                    Margin="0,4,0,0"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Warning24" FontSize="14"
                                   Foreground="#FFDC2626"
                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MessageErreur}"
                               Foreground="#FF7F1D1D"
                               FontSize="11"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="24,16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Annuler"
                        Command="{Binding AnnulerCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>

                <Button Grid.Column="2"
                        Content="Vérifier"
                        Click="BtnVerifier_Click"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
