<ui:FluentWindow x:Class="Metrologo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Metrologo.ViewModels"
        xmlns:views="clr-namespace:Metrologo.Views"
        mc:Ignorable="d"
        Title="{Binding TitreApplication}"
        Height="720" Width="1080"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Icon="/Resources/logo.ico">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <DataTemplate DataType="{x:Type vm:AccueilViewModel}">
            <views:AcceuilView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdminViewModel}">
            <views:AdminView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SelectionPosteViewModel}">
            <views:SelectionPosteView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SelectionScanModeViewModel}">
            <views:SelectionScanModeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SelectionUtilisateurViewModel}">
            <views:SelectionUtilisateurView />
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{Binding TitreApplication}"
                     ShowMaximize="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/logo.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Barre de navigation avec logo -->
        <Border Grid.Row="1"
                Padding="20,12"
                Background="{StaticResource AsertiNavyBrush}"
                Visibility="{Binding NavigationActive, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo ASERTI -->
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="6"
                        Padding="10,6"
                        Margin="0,0,24,0"
                        VerticalAlignment="Center">
                    <Image Source="/Resources/aserti-logo.png"
                           Height="40"
                           Stretch="Uniform"/>
                </Border>

                <!-- Navigation — dans un ScrollViewer horizontal : sur un petit écran la barre
                     défile au lieu de déborder et chevaucher la zone utilisateur à droite. -->
                <ScrollViewer Grid.Column="1" VerticalAlignment="Center"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Auto">
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding AllerAccueilCommand}"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Home24" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Accueil" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding OuvrirAdminCommand}"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ShieldKeyhole24" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Administration" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Diagnostic GPIB : à côté d'Administration car concerne le matériel,
                         pas la mesure en cours. Badge = nombre d'appareils détectés. -->
                    <Button Command="{Binding Accueil.OuvrirDiagnosticGpibCommand}"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,6,0"
                            ToolTip="{Binding Accueil.ResumeScanGpib}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="PlugConnected24" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Diagnostic GPIB" VerticalAlignment="Center"/>
                            <Border MinWidth="22" Height="20" CornerRadius="10"
                                    Padding="6,0" Margin="8,0,0,0"
                                    Background="{StaticResource AsertiOrangeBrush}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding Accueil.NbAppareilsDetectes}"
                                           Foreground="White"
                                           FontWeight="Bold" FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding Accueil.RescannerCommand}"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,6,0"
                            ToolTip="Relancer un scan GPIB maintenant"
                            Padding="8,6">
                        <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="16"/>
                    </Button>

                    <Button Command="{Binding RetourAccueilCommand}"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,6,0"
                            Visibility="{Binding EstEnModeAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Retour" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Changer d'utilisateur : revient à l'écran de connexion sans quitter l'app
                         (relais d'opérateur, ou prise en compte immédiate d'un compte tout juste créé). -->
                    <Button Command="{Binding ChangerUtilisateurCommand}"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,6,0"
                            ToolTip="Revenir à l'écran de connexion pour changer d'opérateur">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Person24" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Changer d'utilisateur" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                </ScrollViewer>

                <!-- Utilisateur connecté (en gros) + bouton Quitter, à droite — à l'opposé de la
                     navigation (Accueil / Administration…). -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Indicateur persistant : changements admin reçus d'un autre poste.
                         Reste affiché jusqu'au clic (qui montre le détail et l'efface). -->
                    <Button Command="{Binding AcquitterChangementsAdminCommand}"
                            Visibility="{Binding AChangementsAdminEnAttente, Converter={StaticResource BoolToVisibilityConverter}}"
                            ToolTip="{Binding ResumeChangementsAdmin}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Margin="0,0,18,0" Padding="2" VerticalAlignment="Center">
                        <Grid>
                            <ui:SymbolIcon Symbol="Warning24" FontSize="26" Foreground="#FFFBBF24"/>
                            <Border Background="#FFDC2626" CornerRadius="8" MinWidth="16" Height="16"
                                    Padding="3,0" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,-6,-8,0">
                                <TextBlock Text="{Binding NbChangementsAdmin}" Foreground="White"
                                           FontSize="9" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>
                    <ui:SymbolIcon Symbol="Person24" FontSize="22"
                                   Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding TexteUtilisateurConnecte}"
                               Foreground="White"
                               FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center"
                               MaxWidth="280" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding TexteUtilisateurConnecte}"
                               Margin="0,0,20,0"/>
                    <Button Command="{Binding QuitterCommand}"
                            Style="{StaticResource NavAccentButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Power24" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Quitter" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl Grid.Row="2"
                        Content="{Binding VueActuelle}"
                        Margin="16,16,16,8"/>

        <!-- Barre de statut -->
        <Border Grid.Row="3"
                Padding="20,10"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                Visibility="{Binding NavigationActive, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <Border Width="8" Height="8" CornerRadius="4"
                        Background="{StaticResource AsertiOrangeBrush}"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"/>
                <TextBlock Text="{Binding TexteMode}" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{StaticResource AsertiNavyBrush}"/>
                <Rectangle Width="1" Fill="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="16,2"/>
                <!-- Le nom d'utilisateur connecté est désormais affiché en gros dans le bandeau
                     bleu de navigation (à droite, près de « Quitter »). -->
                <ui:SymbolIcon Symbol="Timer24" Margin="0,0,8,0" FontSize="14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="{Binding RubidiumActifTexte}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
